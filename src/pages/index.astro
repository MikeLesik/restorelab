---
// Root redirect page — fallback for non-Cloudflare environments (local dev).
// On Cloudflare Pages, functions/index.ts handles this at the edge (faster).
---
<script>
(function () {
  const VALID = ['en', 'es', 'ca'];

  // Respect a stored language preference; otherwise default to ES.
  // Smart IP / Accept-Language routing is handled at the edge (functions/index.ts).
  const stored = localStorage.getItem('preferred_lang');
  if (stored && VALID.includes(stored)) {
    window.location.replace('/' + stored);
    return;
  }
  window.location.replace('/es');
})();
</script>
<noscript>
  <meta http-equiv="refresh" content="0; url=/es" />
</noscript>
<p style="font-family:sans-serif;text-align:center;margin-top:4rem">
  Redirecting… <a href="/es">Click here if not redirected</a>
</p>
