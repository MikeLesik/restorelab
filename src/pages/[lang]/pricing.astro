---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PricingCards from '@/components/PricingCards.astro';
import Estimator from '@/components/Estimator.astro';
import FAQ from '@/components/FAQ.astro';
import LeadForm from '@/components/LeadForm.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
---

<BaseLayout
  title={t.meta.pricing.title}
  description={t.meta.pricing.description}
  lang={lang}
  t={t}
  currentPath="/pricing"
>
  <div class="pt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-0 text-center">
      <h1 class="section-title text-5xl mb-4">{t.pricing.section_title}</h1>
      <p class="section-subtitle mx-auto">{t.pricing.section_subtitle}</p>
    </div>

    <Estimator t={t} lang={lang} />
    <PricingCards t={t} lang={lang} />

    <!-- Direct answer for "precio tratamiento cerámico coche" queries -->
    {t.pricing.ceramic_answer && (
      <section id={t.pricing.ceramic_answer.id} class="pb-10">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="card p-6 sm:p-8">
            <h2 class="text-2xl font-display font-bold text-th-heading mb-4">
              {t.pricing.ceramic_answer.title}
            </h2>
            {t.pricing.ceramic_answer.paragraphs.map((p: string) => (
              <p class="text-th-body/80 leading-relaxed mb-4 last:mb-0">{p}</p>
            ))}
          </div>
        </div>
      </section>
    )}

    <FAQ t={t} />
    <LeadForm t={t} lang={lang} />
  </div>
</BaseLayout>
