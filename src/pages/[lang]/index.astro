---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import ServicesGrid from '@/components/ServicesGrid.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import PricingCards from '@/components/PricingCards.astro';
import FAQ from '@/components/FAQ.astro';
import BeforeAfterCarousel from '@/components/BeforeAfterCarousel.astro';
import GuaranteeBlock from '@/components/GuaranteeBlock.astro';

import BrandsStrip from '@/components/BrandsStrip.astro';
import CertificationsRow from '@/components/CertificationsRow.astro';
import Estimator from '@/components/Estimator.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
---

<BaseLayout
  title={t.meta.home.title}
  description={t.meta.home.description}
  lang={lang}
  ogImage={t.meta.home.og_image}
  t={t}
  currentPath=""
>
  <Hero t={t} lang={lang} />
  <BrandsStrip t={t} />
  <ServicesGrid t={t} lang={lang} exclude={['acrylic-restoration', 'trim-restoration']} />
  <HowItWorks t={t} lang={lang} />
  <BeforeAfterCarousel t={t} lang={lang} />
  <PricingCards t={t} lang={lang} categoryId="car" title={t.pricing.home_title} />
  <Estimator t={t} lang={lang} source="home" />
  <GuaranteeBlock t={t} />
  <CertificationsRow t={t} />
  <FAQ t={t} only={['money', 'map', 'user', 'clock', 'shield']} subtitle={t.faq.short_subtitle} showCta={false} />
</BaseLayout>
