---
import BaseLayout from '@/layouts/BaseLayout.astro';
import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
---

<BaseLayout
  title={t.meta.privacy.title}
  description={t.meta.privacy.description}
  lang={lang}
  t={t}
  currentPath="/privacy"
>
  <div class="pt-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="section-title text-4xl mb-8">{t.footer.privacy}</h1>

      <div class="prose dark:prose-invert prose-sm max-w-none text-th-body/80 space-y-8">
        <!-- RGPD data controller (art. 13) — per-language, from content JSON -->
        <section class="rounded-xl border border-brand-accent/20 bg-brand-accent/5 p-5">
          <h2 class="text-th-heading font-semibold text-lg mb-3">{t.privacy_responsable.title}</h2>
          <p class="leading-relaxed">{t.privacy_responsable.text}</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">1. Information We Collect</h2>
          <p>When you contact us via our website form or WhatsApp, we collect the information you voluntarily provide, including your name, phone number, location, and details about your vehicle.</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">2. How We Use Your Information</h2>
          <p>Your information is used solely to respond to your service inquiry, provide a quote, and schedule your appointment. We do not sell or share your data with third parties for marketing purposes.</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">3. Data Retention</h2>
          <p>We retain your contact information only as long as necessary to complete the service and for any follow-up warranty purposes. You may request deletion of your data at any time.</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">4. Cookies</h2>
          <p>This website uses strictly necessary cookies for basic functionality. Analytics cookies (Google Tag Manager, Microsoft Clarity) and marketing cookies (Meta Pixel) are loaded only after you give consent through the cookie banner. See the <a href={`/${lang}/cookies`} class="text-brand-accent hover:underline">Cookie Policy</a> for details and to manage your consent.</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">5. Your Rights (GDPR)</h2>
          <p>Under GDPR, you have the right to access, correct, or delete your personal data. Contact us via WhatsApp or our contact form to exercise these rights.</p>
        </section>

        <section>
          <h2 class="text-th-heading font-semibold text-lg mb-3">6. Contact</h2>
          <p>For privacy-related inquiries, please contact us via the <a href={`/${lang}/contact`} class="text-brand-accent hover:underline">contact page</a>.</p>
          <p class="mt-2 text-th-faint text-xs">Last updated: January 2025</p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
