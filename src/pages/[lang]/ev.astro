---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import CertificationsRow from '@/components/CertificationsRow.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { SITE_URL, WHATSAPP_NUMBER } from '@/lib/constants';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const ev = t.ev || {};
const wa = WHATSAPP_NUMBER;
const waMsg = lang === 'es'
  ? 'Hola restoreLab! Tengo un vehículo eléctrico y me interesa la protección de pintura.'
  : lang === 'ca'
  ? 'Hola restoreLab! Tinc un vehicle elèctric i m\'interessa la protecció de pintura.'
  : 'Hello restoreLab! I have an electric vehicle and I\'m interested in paint protection.';
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(waMsg)}`;
---

<BaseLayout
  title={t.meta.ev?.title || 'EV Paint Protection | restoreLab'}
  description={t.meta.ev?.description || ''}
  lang={lang}
  t={t}
  currentPath="/ev"
>
  <div class="pt-20">
    <!-- Hero -->
    <section class="relative py-16 sm:py-20 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 bg-green-500/10 border border-green-500/20 rounded-full text-green-400 text-xs font-medium mb-6">
            ⚡ EV Specialist
          </span>

          <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-6 leading-tight">
            {ev.hero_title}
          </h1>
          <p class="text-xl text-th-muted mb-10">{ev.hero_subtitle}</p>

          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp" data-event="ev_hero_wa">
            {ev.hero_cta}
          </a>
        </div>
      </div>
    </section>

    <!-- Breadcrumb Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
        { "@type": "ListItem", "position": 2, "name": "EV Paint Protection" }
      ]
    })} />

    <!-- Service Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Electric Vehicle Paint Protection",
      "provider": {
        "@type": "AutomotiveBusiness",
        "name": "restoreLab"
      },
      "areaServed": ["Sant Cugat del Vallès", "Barcelona", "Terrassa", "Sabadell"],
      "description": t.meta.ev?.description,
      "offers": [
        { "@type": "Offer", "name": "EV New-Car Protection", "price": "749", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "EV Premium Shield", "price": "1290", "priceCurrency": "EUR" }
      ]
    })} />

    <!-- Pain Points -->
    <section class="py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-10">{ev.pain_points_title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {ev.pain_points?.map((pp: any) => (
            <div class="card p-6">
              <h3 class="text-th-heading font-semibold text-sm mb-2">{pp.title}</h3>
              <p class="text-th-muted text-xs leading-relaxed">{pp.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- EV Packages -->
    <section class="py-14 bg-th-surface/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="section-title mb-2">{ev.packages_title}</h2>
          <p class="text-th-muted text-sm">{ev.packages_subtitle}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {ev.packages?.map((pkg: any) => (
            <div class:list={['card p-6 relative', pkg.popular && 'border-brand-accent/30 bg-brand-accent/5']}>
              {pkg.popular && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 tag text-[10px]">
                  {lang === 'es' ? 'Más Popular' : lang === 'ca' ? 'Més Popular' : 'Most Popular'}
                </span>
              )}
              <h3 class="text-th-heading font-display font-bold text-lg mb-1">{pkg.name}</h3>
              <div class="text-brand-accent font-display font-bold text-3xl mb-1">
                {pkg.price_from ? `${lang === 'es' || lang === 'ca' ? 'desde' : 'from'} €${pkg.price_from}` : `€${pkg.price}`}
              </div>
              <p class="text-th-muted text-xs mb-5">{pkg.desc}</p>
              <ul class="space-y-2 mb-6">
                {pkg.includes?.map((item: string) => (
                  <li class="flex items-start gap-2 text-th-body text-xs">
                    <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-center text-sm" data-event={`ev_pkg_${pkg.id}`}>
                {ev.hero_cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Compatibility Table -->
    <section class="py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-8">{ev.compatibility_title}</h2>
        <div class="card overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-th-border/10">
                <th class="text-left text-th-heading font-semibold p-4 text-xs uppercase tracking-wider">
                  {lang === 'es' ? 'Marca / Modelo' : lang === 'ca' ? 'Marca / Model' : 'Brand / Model'}
                </th>
                <th class="text-left text-th-heading font-semibold p-4 text-xs uppercase tracking-wider">
                  {lang === 'es' ? 'Paquete Recomendado' : lang === 'ca' ? 'Paquet Recomanat' : 'Recommended Package'}
                </th>
              </tr>
            </thead>
            <tbody>
              {ev.compatibility?.map((c: any, idx: number) => (
                <tr class:list={['border-b border-th-border/5', idx % 2 === 0 && 'bg-th-surface/5']}>
                  <td class="p-4 text-th-heading text-xs font-medium">{c.brand}</td>
                  <td class="p-4 text-th-muted text-xs">{c.recommended}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Trust -->
    <CertificationsRow t={t} />

    <!-- EV FAQ -->
    <section class="py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-8">{ev.faq_title}</h2>
        <div class="space-y-4">
          {ev.faq_items?.map((item: any) => (
            <details class="card p-5 group">
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <span class="text-th-heading font-semibold text-sm pr-4">{item.question}</span>
                <svg class="w-5 h-5 text-th-faint flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-th-muted text-sm mt-3 leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 bg-th-surface/5">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="section-title mb-3">{ev.cta_section_title}</h2>
        <p class="text-th-muted text-sm mb-8">{ev.cta_section_subtitle}</p>
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp" data-event="ev_cta_wa">
          <svg class="w-4 h-4 inline mr-1.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {ev.hero_cta}
        </a>
      </div>
    </section>

    <LeadForm t={t} lang={lang} />
  </div>
</BaseLayout>
