---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQ from '@/components/FAQ.astro';
import CertificationsRow from '@/components/CertificationsRow.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { SITE_URL, WHATSAPP_NUMBER } from '@/lib/constants';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const b = t.business || {};
const wa = WHATSAPP_NUMBER;
const waMsg = t.wa_messages.business;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(waMsg)}`;
---

<BaseLayout
  title={t.meta.business?.title || 'B2B Mobile Detailing | restoreLab'}
  description={t.meta.business?.description || ''}
  lang={lang}
  t={t}
  currentPath="/business"
>
  <div class="pt-20">
    <!-- Hero -->
    <section class="relative py-16 sm:py-20 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 bg-brand-gold/10 border border-brand-gold/20 rounded-full text-brand-gold text-xs font-medium mb-6">
            B2B
          </span>

          <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-6 leading-tight">
            {b.hero_title}
          </h1>
          <p class="text-xl text-th-muted mb-10">{b.hero_subtitle}</p>

          <div class="flex flex-wrap gap-4">
            <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp" data-event="b2b_hero_wa">
              {b.hero_cta}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Breadcrumb Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
        { "@type": "ListItem", "position": 2, "name": "Business" }
      ]
    })} />

    <!-- Service Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "B2B Mobile Vehicle Detailing",
      "provider": {
        "@type": "AutomotiveBusiness",
        "name": "restoreLab"
      },
      "areaServed": ["Sant Cugat del Vallès", "Barcelona", "Terrassa", "Sabadell", "Rubí", "Cerdanyola del Vallès", "Castelldefels"],
      "description": t.meta.business?.description,
      "offers": [
        { "@type": "Offer", "name": "Lot-Ready Standard", "price": "169", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Lot-Ready SUV", "price": "229", "priceCurrency": "EUR" },
        { "@type": "Offer", "name": "Showroom Sports", "price": "299", "priceCurrency": "EUR" }
      ]
    })} />

    <!-- Value Props -->
    <section class="py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-10">{b.value_props_title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {b.value_props?.map((vp: any) => (
            <div class="card p-6 text-center">
              <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-brand-accent/10 flex items-center justify-center">
                {vp.icon === 'clock' && (
                  <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                )}
                {vp.icon === 'camera' && (
                  <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                )}
                {vp.icon === 'invoice' && (
                  <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                )}
                {vp.icon === 'shield' && (
                  <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                )}
              </div>
              <h3 class="text-th-heading font-semibold text-sm mb-2">{vp.title}</h3>
              <p class="text-th-muted text-xs leading-relaxed">{vp.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- B2B Pricing -->
    <section class="py-14 bg-th-surface/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="section-title mb-2">{b.pricing_title}</h2>
          <p class="text-th-muted text-sm">{b.pricing_subtitle}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
          {b.pricing_tiers?.map((tier: any, idx: number) => (
            <div class:list={['card p-6', idx === 2 && 'border-brand-accent/30 bg-brand-accent/5']}>
              <h3 class="text-th-heading font-display font-bold text-lg mb-1">{tier.name}</h3>
              <div class="text-brand-accent font-display font-bold text-3xl mb-3">€{tier.price}</div>
              <p class="text-th-muted text-xs mb-5">{tier.desc}</p>
              <ul class="space-y-2">
                {tier.includes?.map((item: string) => (
                  <li class="flex items-start gap-2 text-th-body text-xs">
                    <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <!-- Volume Discounts -->
        <div class="max-w-lg mx-auto">
          <h3 class="text-th-heading font-semibold text-sm text-center mb-4">{b.volume_title}</h3>
          <div class="flex justify-center gap-4">
            {b.volume_tiers?.map((v: any) => (
              <div class="card p-4 text-center flex-1">
                <div class="text-brand-accent font-display font-bold text-lg">{v.discount}</div>
                <div class="text-th-faint text-xs mt-1">{v.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Trust signals -->
    <CertificationsRow t={t} />

    <!-- B2B FAQ -->
    <section class="py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-8">{b.faq_title}</h2>
        <div class="space-y-4">
          {b.faq_items?.map((item: any) => (
            <details class="card p-5 group">
              <summary class="flex items-center justify-between cursor-pointer list-none">
                <span class="text-th-heading font-semibold text-sm pr-4">{item.question}</span>
                <svg class="w-5 h-5 text-th-faint flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-th-muted text-sm mt-3 leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 bg-th-surface/5">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="section-title mb-3">{b.cta_section_title}</h2>
        <p class="text-th-muted text-sm mb-8">{b.cta_section_subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp" data-event="b2b_cta_wa">
            {b.cta_whatsapp}
          </a>
          <a href={`mailto:support@restorelab.io?subject=B2B%20Inquiry`} class="btn-secondary" data-event="b2b_cta_email">
            {b.cta_email}
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
