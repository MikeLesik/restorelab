---
import BaseLayout from '@/layouts/BaseLayout.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { SITE_URL } from '@/lib/constants';
import { defaultAuthor } from '@/lib/authorBio';
import RelatedGuides from '@/components/RelatedGuides.astro';
import ServiceCTA from '@/components/ServiceCTA.astro';
import { findClusterForSpoke } from '@/lib/clusterMap';

export function getStaticPaths() {
  const langs = [
    { lang: 'en', t: en },
    { lang: 'es', t: es },
    { lang: 'ca', t: ca },
  ];

  return langs.flatMap(({ lang, t }) =>
    t.academy.articles
      .filter((a: any) => a.status === 'published' && a.slug)
      .map((a: any) => ({
        params: { lang, slug: a.slug },
        props: { t, card: a },
      }))
  );
}

const { lang, slug } = Astro.params;
const { t, card } = Astro.props;
const contentKey = (slug as string).replace(/-/g, '_');
const content = (t.academy_articles as Record<string, any>)[contentKey];
const sections = content.sections as Array<Record<string, any>>;

// Determine the article's cluster hub for breadcrumb schema enrichment.
const clusterFound = findClusterForSpoke(slug as string);
const hubLabelKey = clusterFound?.cluster.hubLabelKey;
const hubLabel = hubLabelKey ? ((t.cluster_ui?.hubs as Record<string, string> | undefined)?.[hubLabelKey]) : undefined;
const hubUrl = clusterFound?.cluster.hubActive ? clusterFound.cluster.hub : undefined;
---

<BaseLayout
  title={content.seo_title}
  description={content.seo_description}
  lang={lang}
  t={t}
  currentPath={`/academy/${slug}`}
>
  <!-- BlogPosting Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": content.title,
    "description": content.seo_description,
    "author": {
      "@type": "Person",
      "name": defaultAuthor.name,
      "url": `${SITE_URL}/${lang}${defaultAuthor.url}`
    },
    "publisher": {
      "@type": "Organization",
      "name": "restoreLab",
      "logo": {
        "@type": "ImageObject",
        "url": `${SITE_URL}/favicon.svg`
      }
    },
    "datePublished": card.date || "2025-01-15",
    "dateModified": card.date || "2025-01-15",
    "mainEntityOfPage": `${SITE_URL}/${lang}/academy/${slug}`
  })} />

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
      { "@type": "ListItem", "position": 2, "name": t.academy.articles_title, "item": `${SITE_URL}/${lang}/academy` },
      ...(hubLabel && hubUrl ? [{ "@type": "ListItem", "position": 3, "name": hubLabel, "item": `${SITE_URL}/${lang}${hubUrl}` }] : []),
      { "@type": "ListItem", "position": hubLabel && hubUrl ? 4 : 3, "name": content.title, "item": `${SITE_URL}/${lang}/academy/${slug}` }
    ]
  })} />

  <div class="pt-24">

    <!-- Hero -->
    <section class="relative py-14 sm:py-16 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <a href={`/${lang}/academy`} class="inline-flex items-center gap-2 text-sm text-th-faint hover:text-th-heading mb-5 transition-colors focus-visible:ring-2 focus-visible:ring-brand-accent rounded">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t.academy.back_label}
        </a>

        <!-- Number tag -->
        <span class="tag mb-4 inline-block">{card.number}</span>

        <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-4 leading-tight">
          {content.title}
        </h1>
        <p class="text-xl text-th-muted mb-0 leading-relaxed">
          {content.description}
        </p>
      </div>
    </section>

    <!-- Article body -->
    <article class="py-10 sm:py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Intro -->
        <p class="text-lg text-th-body leading-relaxed mb-10">
          {content.intro}
        </p>

        <!-- Sections -->
        {sections.map((section) => (
          <section class="mb-12">
            <!-- Section heading -->
            <div class="flex items-center gap-4 mb-5">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-accent/10 border border-brand-accent/20 flex items-center justify-center text-brand-accent font-display font-bold text-sm">
                {section.number}
              </span>
              <h2 class="text-2xl md:text-3xl font-display font-bold text-th-heading">
                {section.title}
              </h2>
            </div>

            <!-- Paragraphs -->
            {section.paragraphs?.map((p: string) => (
              <p class="text-th-body/80 leading-relaxed mb-6">{p}</p>
            ))}

            <!-- Key params (bullet list) -->
            {section.key_params && (
              <ul class="space-y-3 mb-6">
                {section.key_params.map((param: string) => (
                  <li class="flex items-start gap-3 text-th-body">
                    <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="leading-relaxed">{param}</span>
                  </li>
                ))}
              </ul>
            )}

            <!-- Analogy / engineering callout -->
            {section.analogy && (
              <div class="relative rounded-2xl border border-brand-gold/20 bg-brand-gold/5 p-5 sm:p-6 mb-6">
                <div class="absolute top-0 left-6 -translate-y-1/2 px-3 py-1 bg-brand-dark rounded-full border border-brand-gold/20">
                  <span class="text-brand-gold text-xs font-semibold uppercase tracking-wider">{section.analogy.title}</span>
                </div>
                <p class="text-th-body leading-relaxed mt-2">{section.analogy.text}</p>
              </div>
            )}

            <!-- Comparison table -->
            {section.table && (
              <div class="mb-6">
                <p class="text-sm font-semibold text-brand-accent uppercase tracking-wider mb-4">{section.table.caption}</p>
                <div class="overflow-x-auto rounded-xl border border-th-border/10">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-th-border/10 bg-th-surface/5">
                        {section.table.headers.map((header: string) => (
                          <th class="px-4 py-3 text-left font-semibold text-th-heading whitespace-nowrap">{header}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {section.table.rows.map((row: string[], idx: number) => (
                        <tr class:list={["border-b border-th-border/5", { "bg-th-surface/[0.02]": idx % 2 === 1 }]}>
                          {row.map((cell: string, cellIdx: number) => (
                            <td class:list={["px-4 py-3 whitespace-nowrap", cellIdx === 0 ? "font-medium text-th-heading" : "text-th-body/80"]}>
                              {cell}
                            </td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- Conclusion -->
            {section.conclusion && (
              <p class="text-th-body leading-relaxed font-medium border-l-2 border-brand-accent pl-4 mb-6">
                {section.conclusion}
              </p>
            )}

            <!-- Tools / labeled list (table layout for aligned columns) -->
            {section.tools && (
              <div class="mb-6">
                {section.tools_title && (
                  <p class="text-sm font-semibold text-brand-accent uppercase tracking-wider mb-3">{section.tools_title}</p>
                )}
                <div class="rounded-xl border border-th-border/5 overflow-hidden">
                  <table class="w-full">
                    <tbody>
                      {section.tools.map((tool: { label: string; text: string }, idx: number) => (
                        <tr class:list={["bg-th-surface/[0.03]", idx > 0 && "border-t border-th-border/5"]}>
                          <td class="py-3 pl-4 pr-2 align-middle whitespace-nowrap">
                            <span class="inline-block px-2.5 py-1 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-brand-accent text-xs font-medium">
                              {tool.label}
                            </span>
                          </td>
                          <td class="py-3 pr-4 pl-2 text-th-body/80 leading-relaxed">
                            {tool.text}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}
          </section>
        ))}

      </div>
    </article>

    <ServiceCTA slug={slug as string} t={t} lang={lang as string} />
    <RelatedGuides slug={slug as string} t={t} lang={lang as string} />

  </div>
</BaseLayout>
