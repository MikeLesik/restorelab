---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQ from '@/components/FAQ.astro';
import AreaServedSection from '@/components/AreaServedSection.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { WHATSAPP_NUMBER } from '@/lib/constants';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.contact)}`;
---

<BaseLayout
  title={t.meta.contact.title}
  description={t.meta.contact.description}
  lang={lang}
  t={t}
  currentPath="/contact"
>
  <div class="pt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Info side -->
        <div>
          <h1 class="section-title text-5xl mb-6">{t.meta.contact.title.split('—')[0]}</h1>
          <p class="text-th-muted text-lg leading-relaxed mb-10">{t.meta.contact.description}</p>

          <!-- Contact options -->
          <div class="space-y-4 mb-10">
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-5 bg-green-500/10 border border-green-500/20 rounded-2xl hover:border-green-500/40 transition-colors group"
            >
              <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="currentColor">
                  <use href="#icon-whatsapp" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-th-heading group-hover:text-green-300 transition-colors">WhatsApp</div>
                <div class="text-sm text-th-muted">{t.ui.fastest_response}</div>
              </div>
            </a>
          </div>

          <!-- Areas -->
          <div>
            <h3 class="text-sm font-semibold text-th-faint uppercase tracking-widest mb-4">{t.area.section_title}</h3>
            <div class="flex flex-wrap gap-2">
              {t.area.hubs.map((hub: any) => (
                <span class="px-3 py-1.5 bg-th-surface/5 border border-th-border/10 rounded-full text-xs text-th-muted">
                  {hub.city}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Form side (inline) -->
        <div class="card">
          <h2 class="font-display font-bold text-th-heading text-2xl mb-2">{t.lead_form.section_title}</h2>
          <p class="text-th-muted text-sm mb-8">{t.lead_form.section_subtitle}</p>

          <form id="contact-lead-form" class="space-y-5">
            <div>
              <label for="contact-name" class="block text-sm font-medium text-th-body/80 mb-2">
                {t.lead_form.fields.name} <span class="text-brand-accent">*</span>
              </label>
              <input id="contact-name" type="text" name="name" required maxlength="100" placeholder={t.lead_form.fields.name_placeholder}
                class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm" />
            </div>

            <div>
              <label for="contact-phone" class="block text-sm font-medium text-th-body/80 mb-2">
                {t.lead_form.fields.phone} <span class="text-brand-accent">*</span>
              </label>
              <input id="contact-phone" type="tel" name="phone" required maxlength="20" placeholder={t.lead_form.fields.phone_placeholder}
                class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm" />
            </div>

            <div>
              <label for="contact-service" class="block text-sm font-medium text-th-body/80 mb-2">{t.lead_form.fields.service}</label>
              <select id="contact-service" name="service" class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm appearance-none">
                <option value="" class="bg-brand-navy">—</option>
                {t.lead_form.fields.service_options.map((opt: string) => (
                  <option value={opt} class="bg-brand-navy">{opt}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="contact-location" class="block text-sm font-medium text-th-body/80 mb-2">{t.lead_form.fields.location}</label>
              <input id="contact-location" type="text" name="location" maxlength="100" placeholder={t.lead_form.fields.location_placeholder}
                class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm" />
            </div>

            <div>
              <label for="contact-message" class="block text-sm font-medium text-th-body/80 mb-2">{t.lead_form.fields.message}</label>
              <textarea id="contact-message" name="message" rows="4" maxlength="1000" placeholder={t.lead_form.fields.message_placeholder}
                class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm resize-none"></textarea>
            </div>

            <button type="submit" class="w-full btn-whatsapp py-4 text-base font-bold">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <use href="#icon-whatsapp" />
              </svg>
              {t.lead_form.fields.submit}
            </button>
          </form>
        </div>
      </div>
    </div>

    <AreaServedSection t={t} />
    <FAQ t={t} />
  </div>
</BaseLayout>

<script define:vars={{ waNumber: wa, template: t.lead_form.whatsapp_template, notSpecified: t.lead_form.not_specified, noInfo: t.lead_form.no_info }}>
  document.getElementById('contact-lead-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);

    const name     = data.get('name')     || '';
    const phone    = data.get('phone')    || '';
    const service  = data.get('service')  || notSpecified;
    const location = data.get('location') || notSpecified;
    const message  = data.get('message')  || noInfo;

    const text = template
      .replace('{name}',     name)
      .replace('{phone}',    phone)
      .replace('{service}',  service)
      .replace('{location}', location)
      .replace('{message}',  message);

    window.location.href = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(text);
  });
</script>
