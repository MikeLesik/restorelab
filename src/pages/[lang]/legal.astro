---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LegalSections from '@/components/LegalSections.astro';
import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
---

<BaseLayout
  title={t.meta.legal.title}
  description={t.meta.legal.description}
  lang={lang}
  t={t}
  currentPath="/legal"
>
  <div class="pt-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="section-title text-4xl mb-8">{t.legal_notice.title}</h1>
      <LegalSections page={t.legal_notice} lang={lang} />
    </div>
  </div>
</BaseLayout>
