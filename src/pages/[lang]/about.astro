---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CertificationsRow from '@/components/CertificationsRow.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { SITE_URL } from '@/lib/constants';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const about = t.about;
---

<BaseLayout
  title={t.meta.about.title}
  description={t.meta.about.description}
  lang={lang}
  t={t}
  currentPath="/about"
>
  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
      { "@type": "ListItem", "position": 2, "name": "About" }
    ]
  })} />

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "restoreLab",
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/favicon.svg`
    },
    "description": t.meta.about.description,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant Cugat del Vallès",
      "addressRegion": "Catalonia",
      "postalCode": "08195",
      "addressCountry": "ES"
    },
    "founder": {
      "@type": "Person",
      "name": about.founder_name
    }
  })} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section class="pt-24 pb-10">
      <h1 class="section-title mb-4">{about.hero_title}</h1>
      <p class="lead max-w-2xl">{about.hero_subtitle}</p>
    </section>

    <!-- Stats -->
    <section class="pb-10">
      <div class="grid grid-cols-2 gap-4 max-w-2xl">
        {about.stats.map((stat: any) => (
          <div class="card text-center py-6">
            <div class="text-2xl sm:text-3xl font-display font-bold text-brand-accent mb-1">{stat.value}</div>
            <div class="text-xs text-th-muted uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Founder -->
    <section class="pb-10">
      <div class="card p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start">
        <div class="w-20 h-20 rounded-full bg-brand-accent/15 border-2 border-brand-accent/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-10 h-10 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-th-heading font-display font-bold text-xl mb-1">{about.founder_name}</h2>
          <p class="text-brand-accent text-sm font-medium mb-3">{about.founder_role}</p>
          <p class="text-th-body/80 text-sm leading-relaxed">{about.origin_text}</p>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="pb-10">
      <h2 class="text-th-heading font-display font-bold text-xl mb-4">{about.philosophy_title}</h2>
      <p class="text-th-body/80 text-sm leading-relaxed">{about.philosophy_text}</p>
    </section>

    <!-- Equipment -->
    <section class="pb-10">
      <h2 class="text-th-heading font-display font-bold text-xl mb-4">{about.equipment_title}</h2>
      <p class="text-th-body/80 text-sm leading-relaxed mb-6">{about.equipment_text}</p>
    </section>

  </div>

  <!-- Brands & Certifications -->
  <CertificationsRow t={t} equipment={false} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Local Commitment -->
    <section class="pb-10">
      <h2 class="text-th-heading font-display font-bold text-xl mb-4">{about.local_title}</h2>
      <p class="text-th-body/80 text-sm leading-relaxed">{about.local_text}</p>
    </section>

  </div>
</BaseLayout>
