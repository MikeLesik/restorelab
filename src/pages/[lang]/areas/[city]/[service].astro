---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQ from '@/components/FAQ.astro';
import { WHATSAPP_NUMBER, SITE_URL } from '@/lib/constants';
import { areaProfiles } from '@/lib/areaProfiles';
import { serviceProfiles } from '@/lib/serviceProfiles';
import { generateAreaServiceContent, CANARY_PAIRS, type Lang } from '@/lib/areaServiceContent';
import { clusterMap } from '@/lib/clusterMap';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  // Canary scope: ES only. CANARY_PAIRS = 12 (city, service) tuples.
  const langs: Array<{ lang: Lang; t: any }> = [
    { lang: 'es', t: es },
  ];

  return langs.flatMap(({ lang, t }) =>
    CANARY_PAIRS.map((pair) => ({
      params: { lang, city: pair.city, service: pair.service },
      props: { t, lang, citySlug: pair.city, serviceId: pair.service },
    }))
  );
}

const { lang, citySlug, serviceId, t } = Astro.props as {
  lang: Lang;
  citySlug: string;
  serviceId: string;
  t: any;
};

const area = areaProfiles[citySlug];
const service = serviceProfiles[serviceId];
const cluster = clusterMap[serviceId];
const slots = generateAreaServiceContent(citySlug, serviceId, t, lang);

// If any data is missing, halt build with informative error
if (!area || !service || !cluster || !slots) {
  throw new Error(`Programmatic page data missing: city=${citySlug} service=${serviceId} lang=${lang}`);
}

const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(slots.ctaWhatsappText)}`;
const hubUrl = `/${lang}${cluster.hub}`;
const areaUrl = `/${lang}/areas/${citySlug}`;

// Service schema as a localized service offering
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": slots.h1,
  "name": slots.title,
  "description": slots.metaDescription,
  "provider": {
    "@type": "AutomotiveBusiness",
    "name": "restoreLab",
    "url": `${SITE_URL}/${lang}`,
  },
  "areaServed": {
    "@type": "City",
    "name": area.name,
  },
  "offers": service.startingPriceEur ? {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "price": String(service.startingPriceEur),
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "EUR",
      "minPrice": service.startingPriceEur,
      "valueAddedTaxIncluded": false,
    },
  } : undefined,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
    { "@type": "ListItem", "position": 2, "name": area.shortName, "item": `${SITE_URL}${areaUrl}` },
    { "@type": "ListItem", "position": 3, "name": slots.h1, "item": `${SITE_URL}/${lang}/areas/${citySlug}/${serviceId}` },
  ],
};
---

<BaseLayout
  title={slots.title}
  description={slots.metaDescription}
  lang={lang}
  t={t}
  currentPath={`/areas/${citySlug}/${serviceId}`}
  availableLangs={['es']}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="pt-24">
    <!-- Hero / H1 -->
    <section class="relative py-14 sm:py-16 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href={areaUrl} class="inline-flex items-center gap-2 text-sm text-th-faint hover:text-th-heading mb-5 transition-colors focus-visible:ring-2 focus-visible:ring-brand-accent rounded">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          {slots.backToAreaLabel}
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-4 leading-tight">{slots.h1}</h1>
        <p class="text-xl text-th-muted mb-0 leading-relaxed">{slots.subtitle}</p>
      </div>
    </section>

    <!-- Slot 1: Intro / Local hook -->
    <section class="py-12 sm:py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-brand-accent uppercase tracking-wider mb-3">{slots.introLabel}</p>
        <p class="text-lg text-th-body leading-relaxed">{slots.introBody}</p>
      </div>
    </section>

    <!-- Slot 4: Pricing -->
    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-th-border/10 bg-th-surface/5 p-6">
          <p class="text-sm font-semibold text-brand-accent uppercase tracking-wider mb-3">{slots.pricingLabel}</p>
          <p class="text-2xl font-display font-bold text-th-heading mb-2">{slots.pricingStartingFrom}</p>
          <p class="text-sm text-th-muted">{slots.pricingTravelLine}</p>
          <a href={hubUrl} class="inline-flex items-center gap-2 mt-4 text-sm text-brand-accent hover:underline" data-event="programmatic_to_hub" data-from-area={citySlug} data-to-hub={serviceId}>
            {slots.backToServiceLabel}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Slot 5: Trust -->
    <section class="py-10">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-brand-accent uppercase tracking-wider mb-3">{slots.trustLabel}</p>
        <p class="text-base text-th-body">{slots.trustCaseLine}</p>
      </div>
    </section>

    <!-- Slot 3: FAQ — uses extended FAQ component (Plan 1 Task 17) -->
    <FAQ
      t={t}
      title={slots.faqLabel}
      subtitle={null}
      items={slots.faqs.map((f) => ({ question: f.question, answer: f.answer }))}
      showCta={false}
    />

    <!-- CTA -->
    <section class="py-12 sm:py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-brand-accent/25 bg-brand-accent/10 p-6 sm:p-8 text-center">
          <p class="text-2xl font-display font-bold text-th-heading mb-2">{slots.ctaTitle}</p>
          <p class="text-th-muted text-sm mb-5">{slots.ctaSubtitle}</p>
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-brand-whatsapp hover:brightness-110 text-white font-semibold rounded-lg transition-all"
            data-event="wa_click"
            data-source="programmatic"
            data-area={citySlug}
            data-service={serviceId}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <use href="#icon-whatsapp" />
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
