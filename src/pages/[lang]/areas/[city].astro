---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQ from '@/components/FAQ.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { WHATSAPP_NUMBER, SITE_URL } from '@/lib/constants';
import { clusterMap, getActiveClusterIds } from '@/lib/clusterMap';
import { serviceProfiles } from '@/lib/serviceProfiles';
import { CANARY_PAIRS } from '@/lib/areaServiceContent';

export function getStaticPaths() {
  const langs = [
    { lang: 'en', t: en },
    { lang: 'es', t: es },
    { lang: 'ca', t: ca },
  ];

  return langs.flatMap(({ lang, t }) =>
    t.area_pages.cities.map((city: any) => ({
      params: { lang, city: city.slug },
      props: { t, city },
    }))
  );
}

const { lang } = Astro.params;
const { t, city } = Astro.props;
const ap = t.area_pages;

// The ES-only area×service pages are the most specific answer to a
// "<service> in <city>" query, but nothing linked to them — 13 of the 14 were
// orphans, reachable only through the sitemap. Where one exists for this city,
// the service card points at it instead of the generic service page.
const canaryServices = new Set(
  lang === 'es'
    ? CANARY_PAIRS.filter((p) => p.city === city.slug).map((p) => p.service)
    : []
);
const serviceHref = (id: string) =>
  canaryServices.has(id) ? `/${lang}/areas/${city.slug}/${id}` : `/${lang}/services/${id}`;
const wa = WHATSAPP_NUMBER;

const fill = (tpl: string) => tpl.replace(/\{city\}/g, city.name);
// area_quote is the template built for this — it carries {city}, so the message
// names the city in every language. (The previous version string-replaced an
// English literal, so the substitution silently did nothing in ES and CA.)
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(fill(t.wa_messages.area_quote))}`;

// Find clusters whose relatedAreas include this city's slug.
// Take up to 3 (prioritize order they appear in clusterMap — primary services first).
const cityRelatedClusters = getActiveClusterIds()
  .map((id) => ({ id, def: clusterMap[id] }))
  .filter(({ def }) => def.relatedAreas.includes(city.slug))
  .slice(0, 3);

// Hub labels lookup (typed as any to allow string indexing in template)
const clusterHubLabels: any = t.cluster_ui?.hubs ?? {};
---

<BaseLayout
  title={fill(ap.meta_title_tpl)}
  description={fill(ap.meta_desc_tpl)}
  lang={lang}
  t={t}
  currentPath={`/areas/${city.slug}`}
>
  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
      { "@type": "ListItem", "position": 2, "name": city.name }
    ]
  })} />

  <div class="pt-24">
    <!-- Hero -->
    <section class="relative py-14 sm:py-16 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block px-3 py-1 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-brand-accent text-xs font-medium mb-6">
          {city.region}
        </span>

        <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-6 leading-tight">
          {fill(ap.h1_tpl)}
        </h1>

        <p class="text-xl text-th-muted mb-8 leading-relaxed">
          {fill(ap.intro_tpl)}
        </p>

        <p class="text-th-body/80 mb-10 max-w-2xl mx-auto leading-relaxed">
          {city.description}
        </p>

        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          {fill(ap.cta_tpl)}
        </a>
      </div>
    </section>

    <!-- Services in this city -->
    <section class="py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-10">{fill(ap.services_heading)}</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {t.services.items.filter((s: any) => !['trim-restoration'].includes(s.id)).map((s: any) => (
            <a
              href={serviceHref(s.id)}
              class="card hover:border-th-border/20 transition-colors group"
              data-event="area_service_click"
              data-area={city.slug}
              data-service={s.id}
            >
              <h3 class="font-display font-semibold text-th-heading text-lg mb-2 group-hover:text-brand-accent transition-colors">{s.title}</h3>
              <p class="text-th-muted text-sm mb-4">{s.subtitle}</p>
              <span class="text-brand-accent text-sm font-medium">{s.starting_price || t.services.get_quote}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Areas covered -->
    <section class="py-12">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-8">{fill(ap.areas_heading)}</h2>

        <div class="flex flex-wrap justify-center gap-3">
          <span class="px-4 py-2 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-brand-accent text-sm font-medium">
            {city.name}
          </span>
          {city.nearby.map((area: string) => (
            <span class="px-4 py-2 bg-th-surface/5 border border-th-border/10 rounded-full text-th-muted text-sm">
              {area}
            </span>
          ))}
        </div>
      </div>
    </section>

    <FAQ t={t} />

    {cityRelatedClusters.length > 0 && (
      <section class="py-12 sm:py-14">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="section-title">{(t.cluster_ui?.areas_dense_links_title || '').replace('{city}', city.name)}</h2>
            {t.cluster_ui?.areas_dense_links_subtitle && (
              <p class="section-subtitle mx-auto mt-3">{t.cluster_ui.areas_dense_links_subtitle}</p>
            )}
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            {cityRelatedClusters.map(({ id, def }) => {
              const label = clusterHubLabels[def.hubLabelKey] || serviceProfiles[id]?.englishLabel || id;
              return (
                <a
                  href={canaryServices.has(id) ? `/${lang}/areas/${city.slug}/${id}` : `/${lang}${def.hub}`}
                  class="group block p-5 rounded-2xl border border-th-border/10 hover:border-brand-accent/40 hover:bg-th-surface/3 transition-all focus-visible:ring-2 focus-visible:ring-brand-accent"
                  data-event="area_service_click"
                  data-area={city.slug}
                  data-service={id}
                >
                  <h3 class="text-base font-display font-semibold text-th-heading group-hover:text-brand-accent transition-colors leading-snug">
                    {label}
                  </h3>
                  {serviceProfiles[id]?.startingPriceEur && (
                    <p class="text-sm text-th-muted mt-2">
                      {lang === 'en' ? 'From' : lang === 'es' ? 'Desde' : 'Des de'} €{serviceProfiles[id]!.startingPriceEur}
                    </p>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}
  </div>
</BaseLayout>
