---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LegalSections from '@/components/LegalSections.astro';
import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const cp = t.cookies_page;
---

<BaseLayout
  title={t.meta.cookies.title}
  description={t.meta.cookies.description}
  lang={lang}
  t={t}
  currentPath="/cookies"
>
  <div class="pt-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="section-title text-4xl mb-4">{cp.title}</h1>
      <p class="text-th-muted mb-10 leading-relaxed">{cp.intro}</p>

      <LegalSections page={cp} lang={lang} />

      <!-- Reopens the CookieConsent preferences modal (v3 data-cc binding) -->
      <button type="button" data-cc="show-preferencesModal" class="btn-secondary mt-10 focus-visible:ring-2 focus-visible:ring-brand-accent">
        {cp.manage_button}
      </button>
    </div>
  </div>
</BaseLayout>
