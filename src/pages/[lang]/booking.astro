---
import BaseLayout from '@/layouts/BaseLayout.astro';

import en from '@/content/en.json';
import es from '@/content/es.json';
import ca from '@/content/ca.json';
import { SITE_URL } from '@/lib/constants';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' }, props: { t: en } },
    { params: { lang: 'es' }, props: { t: es } },
    { params: { lang: 'ca' }, props: { t: ca } },
  ];
}

const { lang } = Astro.params;
const { t } = Astro.props;
const b = t.booking || {};

const calUser = 'mikhail-oorfya';
const estimateSlug = '30min';
const detailSlug = 'detail-booking';
---

<BaseLayout
  title={t.meta.booking?.title || 'Book an Appointment | restoreLab'}
  description={t.meta.booking?.description || ''}
  lang={lang}
  t={t}
  currentPath="/booking"
>
  <div class="pt-20">
    <!-- Hero -->
    <section class="relative py-16 sm:py-20 overflow-hidden bg-gradient-hero">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(42,127,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(42,127,255,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-4 leading-tight">
          {b.hero_title}
        </h1>
        <p class="text-xl text-th-muted max-w-2xl mx-auto">{b.hero_subtitle}</p>
      </div>
    </section>

    <!-- Breadcrumb Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/${lang}` },
        { "@type": "ListItem", "position": 2, "name": "Booking" }
      ]
    })} />

    <!-- Booking Tabs + Embed -->
    <section class="py-14">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Tab Switcher -->
        <div class="flex justify-center gap-3 mb-8" id="booking-tabs">
          <button
            type="button"
            class="px-5 py-2.5 rounded-full text-sm font-medium transition-all text-white bg-brand-accent"
            data-tab="estimate"
          >
            {b.tabs?.estimate || 'Free Estimate'}
          </button>
          <button
            type="button"
            class="px-5 py-2.5 rounded-full text-sm font-medium transition-all text-th-muted hover:text-th-heading bg-th-surface/10"
            data-tab="detail"
          >
            {b.tabs?.detail || 'Detail Booking'}
          </button>
        </div>

        <!-- Tab Descriptions -->
        <p class="text-center text-th-muted text-sm mb-8 max-w-xl mx-auto tab-desc" data-for="estimate">
          {b.estimate_desc}
        </p>
        <p class="text-center text-th-muted text-sm mb-8 max-w-xl mx-auto tab-desc hidden" data-for="detail">
          {b.detail_desc}
        </p>

        <!-- Cal.com Embed Container -->
        <div class="card p-0 overflow-hidden rounded-2xl">
          <div id="cal-embed-estimate">
            <iframe
              id="cal-iframe-estimate"
              src={`https://app.cal.com/${calUser}/${estimateSlug}?embed=true&layout=month_view&theme=dark`}
              width="100%"
              frameborder="0"
              loading="lazy"
              style="border: none; height: 680px;"
              title="Book Estimate Visit"
              allow="payment"
            ></iframe>
          </div>
          <div id="cal-embed-detail" class="hidden">
            <iframe
              id="cal-iframe-detail"
              src={`https://app.cal.com/${calUser}/${detailSlug}?embed=true&layout=month_view&theme=dark`}
              width="100%"
              frameborder="0"
              loading="lazy"
              style="border: none; height: 680px;"
              title="Book Detail Session"
              allow="payment"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Info Section -->
    <section class="py-14 bg-th-surface/5">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-center mb-8">{b.info_title}</h2>
        <div class="space-y-4">
          {b.info_items?.map((item: string) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-th-body text-sm">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- Tab Switching Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.getElementById('booking-tabs');
      if (!tabs) return;

      const buttons = tabs.querySelectorAll('button');
      const descs = document.querySelectorAll('.tab-desc');
      const embedEstimate = document.getElementById('cal-embed-estimate');
      const embedDetail = document.getElementById('cal-embed-detail');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tab = btn.getAttribute('data-tab');

          buttons.forEach(b => {
            if (b.getAttribute('data-tab') === tab) {
              b.classList.add('text-white', 'bg-brand-accent');
              b.classList.remove('text-th-muted', 'bg-th-surface/10');
            } else {
              b.classList.remove('text-white', 'bg-brand-accent');
              b.classList.add('text-th-muted', 'bg-th-surface/10');
            }
          });

          descs.forEach(d => {
            d.classList.toggle('hidden', d.getAttribute('data-for') !== tab);
          });

          if (embedEstimate && embedDetail) {
            embedEstimate.classList.toggle('hidden', tab !== 'estimate');
            embedDetail.classList.toggle('hidden', tab !== 'detail');
          }
        });
      });
    });

    // Auto-resize Cal.com iframes based on postMessage
    window.addEventListener('message', (e) => {
      if (e.origin !== 'https://app.cal.com') return;
      try {
        const data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
        if (data?.type === 'CAL:resize' && data.data?.height) {
          const iframes = document.querySelectorAll<HTMLIFrameElement>('#cal-iframe-estimate, #cal-iframe-detail');
          iframes.forEach(iframe => {
            iframe.style.height = data.data.height + 'px';
          });
        }
      } catch {}
    });
  </script>
</BaseLayout>
