---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.prefooter_cta)}`;
---

<section class="relative pt-12 pb-10 overflow-hidden border-t border-th-border/5">

  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/60 via-brand-navy/30 to-transparent pointer-events-none"></div>

  <!-- Glow spot -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-brand-accent/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Trust pill -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-gold/10 border border-brand-gold/20 rounded-full text-brand-gold text-xs font-medium mb-6">
      {/* Five stars used to sit here. The pill text makes no rating claim; the
          stars did, on every page, with nothing behind them — the reviews and
          the 5.0 came out in 1daf34b for exactly that reason. Put them back
          only alongside a real, attributable rating. */}
      <span>{t.pre_footer_cta.trust_pill}</span>
    </div>

    <!-- Headline -->
    <h2 class="text-4xl md:text-5xl font-display font-bold text-th-heading mb-4 leading-tight">
      {t.pre_footer_cta.title}
    </h2>

    <!-- Subtitle -->
    <p class="text-th-muted text-lg mb-10 max-w-xl mx-auto leading-relaxed">
      {t.pre_footer_cta.subtitle}
    </p>

    <!-- CTA -->
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-event="wa_click"
      class="inline-flex items-center gap-3 px-8 py-4 bg-brand-whatsapp hover:brightness-110 text-white font-bold text-base rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-green-900/30 hover:-translate-y-0.5"
    >
      <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <use href="#icon-whatsapp" />
      </svg>
      {t.pre_footer_cta.cta}
    </a>

    <!-- Reply time + trust -->
    <p class="text-th-faint text-sm mt-5">{t.pre_footer_cta.reply_note}</p>
    <p class="text-th-faint text-xs mt-1">{t.trust.micro_prefooter}</p>
  </div>
</section>
