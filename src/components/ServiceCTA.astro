---
import { findClusterForSpoke } from '@/lib/clusterMap';

export interface Props {
  /** Slug of the current academy article */
  slug: string;
  /** Translations object passed from page */
  t: Record<string, any>;
  /** Language code */
  lang: string;
}

const { slug, t, lang } = Astro.props;

const found = findClusterForSpoke(slug);
const ui = t.cluster_ui || {};
const hubLabel = found && found.cluster.hubLabelKey
  ? ui.hubs?.[found.cluster.hubLabelKey]
  : null;
const hubUrl = found ? `/${lang}${found.cluster.hub}` : null;
const showCta = found?.cluster.hubActive && hubLabel && hubUrl;
---

{showCta && (
  <section class="pb-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-5 sm:p-6 bg-brand-accent/10 border border-brand-accent/25 rounded-2xl">
        <div>
          <p class="text-th-heading font-semibold text-base">{ui.service_cta_title}</p>
          <p class="text-th-muted text-sm mt-1">
            <span class="text-brand-accent font-medium">{hubLabel}</span>
          </p>
        </div>
        <a
          href={hubUrl}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-accent hover:brightness-110 text-white text-sm font-semibold rounded-lg transition-all whitespace-nowrap focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
          data-event="service_cta_click"
          data-from-spoke={slug}
          data-to-hub={found?.clusterId}
        >
          {ui.service_cta_button}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
)}
