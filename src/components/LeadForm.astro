---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
---

<section class="py-24 bg-brand-navy/40" id="contact-form" hidden>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="section-title">{t.lead_form.section_title}</h2>
      <p class="section-subtitle mx-auto">{t.lead_form.section_subtitle}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">

      <!-- Trust sidebar -->
      <div class="lg:col-span-2 space-y-6">
        {t.guarantee?.items?.map((item: any) => (
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-th-heading text-sm mb-1">{item.title}</h4>
              <p class="text-th-faint text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="lg:col-span-3 card">
      <form id="lead-form" data-form="estimate" class="space-y-5">

        <!-- Name -->
        <div>
          <label for="lead-name" class="block text-sm font-medium text-th-body mb-2">
            {t.lead_form.fields.name} <span class="text-brand-accent">*</span>
          </label>
          <input
            id="lead-name"
            type="text"
            name="name"
            required
            maxlength="100"
            placeholder={t.lead_form.fields.name_placeholder}
            class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm"
          />
        </div>

        <!-- Phone -->
        <div>
          <label for="lead-phone" class="block text-sm font-medium text-th-body mb-2">
            {t.lead_form.fields.phone} <span class="text-brand-accent">*</span>
          </label>
          <input
            id="lead-phone"
            type="tel"
            name="phone"
            required
            maxlength="20"
            placeholder={t.lead_form.fields.phone_placeholder}
            class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm"
          />
        </div>

        <!-- Service -->
        <div>
          <label for="lead-service" class="block text-sm font-medium text-th-body mb-2">
            {t.lead_form.fields.service}
          </label>
          <select
            id="lead-service"
            name="service"
            class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm appearance-none"
          >
            <option value="" class="bg-brand-navy">—</option>
            {t.lead_form.fields.service_options.map((opt: string) => (
              <option value={opt} class="bg-brand-navy">{opt}</option>
            ))}
          </select>
        </div>

        <!-- Location -->
        <div>
          <label for="lead-location" class="block text-sm font-medium text-th-body mb-2">
            {t.lead_form.fields.location}
          </label>
          <input
            id="lead-location"
            type="text"
            name="location"
            maxlength="100"
            placeholder={t.lead_form.fields.location_placeholder}
            class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm"
          />
        </div>

        <!-- Message -->
        <div>
          <label for="lead-message" class="block text-sm font-medium text-th-body mb-2">
            {t.lead_form.fields.message}
          </label>
          <textarea
            id="lead-message"
            name="message"
            rows="4"
            maxlength="1000"
            placeholder={t.lead_form.fields.message_placeholder}
            class="w-full px-4 py-3 bg-th-surface/5 border border-th-border/15 rounded-lg text-th-heading placeholder:text-th-faint focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-colors text-sm resize-none"
          ></textarea>
        </div>

        <!-- Photo note -->
        <div class="flex items-start gap-2 p-3 bg-brand-accent/5 border border-brand-accent/15 rounded-lg">
          <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-xs text-th-muted">{t.lead_form.fields.photo_note}</p>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          data-event="estimate_submit"
          class="w-full btn-whatsapp py-4 text-base font-bold"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <use href="#icon-whatsapp" />
          </svg>
          {t.lead_form.fields.submit}
        </button>
      </form>
      </div><!-- end form card -->
    </div><!-- end grid -->
  </div>
</section>

<script define:vars={{ waNumber: wa, template: t.lead_form.whatsapp_template, notSpecified: t.lead_form.not_specified, noInfo: t.lead_form.no_info }}>
  document.getElementById('lead-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);

    const name     = (data.get('name')     || '').toString().slice(0, 100);
    const phone    = (data.get('phone')    || '').toString().slice(0, 20);
    const service  = (data.get('service')  || notSpecified).toString().slice(0, 100);
    const location = (data.get('location') || notSpecified).toString().slice(0, 100);
    const message  = (data.get('message')  || noInfo).toString().slice(0, 1000);

    const text = template
      .replace('{name}',     name)
      .replace('{phone}',    phone)
      .replace('{service}',  service)
      .replace('{location}', location)
      .replace('{message}',  message);

    window.location.href = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(text);
  });
</script>
