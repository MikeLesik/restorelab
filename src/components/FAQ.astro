---
import { faqIcons } from '@/lib/icons';
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  /** Optional override: custom FAQ items (e.g. for an academy article). Falls back to t.faq.items. */
  items?: Array<{ question: string; answer: string; icon?: string }>;
  /** Optional override: section title. Falls back to t.faq.section_title. */
  title?: string;
  /** Optional override: subtitle. Pass null to hide. Falls back to t.faq.section_subtitle. */
  subtitle?: string | null;
  /** Whether to render the contact CTA at the bottom. Default true. */
  showCta?: boolean;
}

const { t, items, title, subtitle, showCta = true } = Astro.props;
const wa = WHATSAPP_NUMBER;
// The FAQ block has its own message: the visitor is here because the answer
// they wanted was not in the list, which is a different intent from the footer.
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.faq ?? t.wa_messages.footer)}`;

const resolvedItems = items ?? t.faq?.items ?? [];
const resolvedTitle = title ?? t.faq?.section_title ?? '';
const resolvedSubtitle = subtitle === null ? null : (subtitle ?? t.faq?.section_subtitle ?? null);

---

<section class="py-12">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-10">
      <h2 class="section-title">{resolvedTitle}</h2>
      {resolvedSubtitle && (
        <p class="section-subtitle mx-auto mt-3">{resolvedSubtitle}</p>
      )}
    </div>

    <!-- Accordion -->
    <div class="rounded-2xl border border-th-border/10 overflow-hidden divide-y divide-th-border/8">
      {resolvedItems.map((item: any, i: number) => {
        const answerId = `faq-answer-${i}`;
        return (
          <details class="group faq-item">
            <summary
              aria-controls={answerId}
              class="flex items-center gap-4 px-5 py-4 cursor-pointer select-none hover:bg-th-surface/3 transition-colors duration-150 [&::-webkit-details-marker]:hidden list-none focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-inset"
            >

              <!-- Icon -->
              <div class="w-9 h-9 rounded-xl bg-brand-accent/10 border border-brand-accent/10 flex items-center justify-center flex-shrink-0 transition-colors duration-200 group-open:bg-brand-accent/20 group-open:border-brand-accent/25">
                <svg
                  class="w-4 h-4 text-brand-accent"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  focusable="false"
                  viewBox="0 0 24 24"
                  set:html={faqIcons[item.icon] || faqIcons['shield']}
                />
              </div>

              <!-- Question -->
              <span class="flex-1 text-th-body font-medium text-sm sm:text-[15px] leading-snug group-open:text-th-heading transition-colors">
                {item.question}
              </span>

              <!-- Chevron -->
              <svg
                class="w-4 h-4 text-th-faint/60 flex-shrink-0 transition-transform duration-200 group-open:rotate-180 group-open:text-brand-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>

            <!-- Answer -->
            <div id={answerId} class="px-5 pb-5 pt-1 faq-answer-body" role="region">
              <div class="pl-[3.25rem]">
                <p class="text-th-muted text-sm leading-relaxed" set:html={item.answer} />
              </div>
            </div>
          </details>
        );
      })}
    </div>

    <!-- CTA -->
    {showCta && (
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-between gap-4 p-5 bg-th-surface/3 border border-th-border/8 rounded-2xl">
        <div>
          <p class="text-th-heading font-medium text-sm">{t.faq.cta_title}</p>
          <p class="text-th-faint text-xs mt-0.5">{t.faq.cta_subtitle}</p>
        </div>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-event="wa_click"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-brand-whatsapp hover:brightness-110 text-white text-sm font-semibold rounded-lg transition-all whitespace-nowrap flex-shrink-0"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <use href="#icon-whatsapp" />
          </svg>
          {t.faq.cta_btn}
        </a>
      </div>
    )}
  </div>
</section>

<!-- FAQPage Schema (SEO) -->
{resolvedItems.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": resolvedItems.map((item: any) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  })} />
)}
