---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
const hw = t.how_it_works;
// WhatsApp copy comes only from t.wa_messages (Critical Rule 3). This URL was
// computed here for months and never rendered; the banner below uses it now.
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.how_it_works)}`;
---

<section class="py-14 bg-brand-navy/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Two columns, not a four-up card grid: the same centred-h2-over-cards
        silhouette every other homepage block already uses reads as one shape
        repeated. The left rail holds the pitch and the ask; the right holds the
        steps. It stacks in DOM order on mobile — heading first, then the steps —
        so the section reads top-down naturally (no order swap). */}
    {/* The left rail is sticky so it travels with the scroll beside the four
        steps. Top-aligned (not vertically centred) so the heading lines up with
        step 01 and the text reads neatly against the sequence. */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-24">
          <h2 class="section-title">{hw.section_title}</h2>
          <p class="section-subtitle mt-3">{hw.section_subtitle}</p>

          {hw.cta_banner && (
            <div class="mt-8 flex items-stretch gap-4 sm:gap-5 rounded-2xl p-5 sm:p-6 bg-brand-whatsapp/10 ring-1 ring-brand-whatsapp/20 dark:backdrop-blur-sm">
              {/* WhatsApp-tinted accent rail — binds the prompt and the ask into one editorial callout */}
              <span class="w-1.5 shrink-0 self-stretch rounded-full bg-brand-whatsapp" aria-hidden="true"></span>

              <div class="min-w-0 flex-1">
                <p class="font-display font-semibold text-th-heading text-[17px] sm:text-lg leading-snug text-balance">
                  {hw.cta_banner}
                </p>

                <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-3">
                  <a
                    href={waUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-event="wa_click"
                    class="btn-whatsapp w-full sm:w-auto"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <use href="#icon-whatsapp" />
                    </svg>
                    {hw.cta_banner_btn}
                  </a>
                  <p class="text-th-faint text-xs leading-snug">{t.trust.micro_pricing}</p>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* role="list" is deliberate: preflight sets list-style:none, and Safari
          then drops list semantics from a styled <ol>, so nothing announces the
          sequence. The numeral is aria-hidden — the list role carries order. */}
      <ol role="list" class="lg:col-span-7 space-y-8">
        {hw.steps.map((step: any, i: number) => (
          <li class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-brand-accent/10 border border-brand-accent/20 flex items-center justify-center" aria-hidden="true">
              <span class="font-display font-bold text-brand-accent text-lg">{step.number ?? String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="pt-1">
              <h3 class="font-display font-bold text-th-heading text-lg mb-1.5">{step.title}</h3>
              <p class="text-th-muted text-sm leading-relaxed">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>

    </div>
  </div>
</section>
