---
export interface Props {
  t: Record<string, any>;
  lang: string;
  categoryId?: string;
  /** Service enrichment passed by /services/* pages so a single merged
   *  Service node is emitted here instead of a second page-level block. */
  serviceType?: string;
  serviceDescription?: string;
  serviceAreaServed?: string[];
}

import { WHATSAPP_NUMBER, SITE_URL } from '@/lib/constants';

const { t, lang, categoryId, serviceType, serviceDescription, serviceAreaServed } = Astro.props;
const wa = WHATSAPP_NUMBER;
const ui = t.pricing.ui || {};

const categories = categoryId
  ? t.pricing.categories.filter((c: any) => c.id === categoryId)
  : t.pricing.categories;

const showMultipliers = !categoryId && ui.size_categories;

function getGridClass(count: number): string {
  if (count === 1) return 'grid-cols-1 max-w-md';
  if (count <= 3) return 'grid-cols-1 md:grid-cols-3';
  return 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
}
---

<section class="pt-8 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {t.pricing.anchor_text && (
      <div class="mb-12 p-5 rounded-xl bg-brand-gold/5 border border-brand-gold/20 text-center">
        <p class="text-brand-gold text-sm font-medium">{t.pricing.anchor_text}</p>
      </div>
    )}

    {categories.map((category: any) => (
        <div class="mb-10">
          <h3 class="font-display font-semibold text-th-muted mb-8 uppercase tracking-widest text-sm border-b border-th-border/10 pb-4">
            {category.title}
          </h3>

          <div class:list={['grid gap-5', getGridClass(category.packages.length)]}>
            {category.packages.map((pkg: any) => (
              <div id={pkg.slug} class:list={[
                'card relative flex flex-col transition-all duration-300',
                pkg.highlight
                  ? 'border-brand-accent/50 bg-brand-accent/5 hover:border-brand-accent'
                  : 'hover:border-th-border/20'
              ]}>
                {pkg.highlight && (
                  <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                    <span class="px-4 py-1 bg-brand-accent text-white text-xs font-bold rounded-full uppercase tracking-wider animate-pulse">
                      {ui.most_popular || 'Most Popular'}
                    </span>
                  </div>
                )}

                <div class="mb-5">
                  <h4 class="font-display font-bold text-th-heading text-lg mb-2">{pkg.name}</h4>
                  <div class="text-2xl font-display font-bold text-brand-accent mb-1">{pkg.price}</div>
                  <div class="text-xs text-th-faint">{pkg.duration}</div>
                </div>

                <p class="text-sm text-th-muted mb-5 leading-relaxed">{pkg.description}</p>

                <ul class="space-y-2 mb-6 flex-1">
                  {pkg.includes.map((item: string) => (
                    <li class="flex items-start gap-2 text-sm text-th-body/80">
                      <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>

                <div class="mt-auto">
                  <div class="text-xs text-th-faint/70 mb-3">
                    <span class="font-medium text-th-muted">{ui.best_for || 'Best for:'}</span> {pkg.best_for}
                  </div>
                  <div class="flex gap-2">
                    <a
                      href={`https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.pricing_plan.replace('{plan}', pkg.name).replace('{category}', category.title))}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={[
                        'flex-1 text-center py-3 rounded-lg font-semibold text-sm transition-colors block',
                        pkg.highlight
                          ? 'bg-brand-accent hover:bg-blue-500 text-white'
                          : 'bg-th-surface/5 hover:bg-th-surface/10 text-th-heading border border-th-border/10'
                      ]}
                    >
                      {ui.get_quote || 'Get Quote'}
                    </a>
                    <a
                      href={`/${lang}/booking`}
                      data-event="pricing_book"
                      class="flex items-center justify-center px-3 py-3 rounded-lg text-sm font-semibold transition-colors border border-brand-accent/30 text-brand-accent hover:bg-brand-accent/10"
                      title={ui.book_visit || 'Book Visit'}
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </a>
                  </div>
                  <p class="text-center text-th-faint text-[10px] mt-2 tracking-wide">{t.trust.micro_pricing}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
    ))}

    <!-- Vehicle Size Multipliers -->
    {showMultipliers && (
      <div class="mt-6 mb-10 p-6 rounded-2xl border border-th-border/10 bg-th-surface/3">
        <h3 class="font-display font-semibold text-th-heading text-lg mb-2">{ui.size_title}</h3>
        <p class="text-sm text-th-muted mb-5">{ui.size_subtitle}</p>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-th-border/10">
                <th class="text-left py-2 pr-4 text-th-muted font-medium">Category</th>
                <th class="text-left py-2 pr-4 text-th-faint font-normal hidden sm:table-cell">Examples</th>
                <th class="text-right py-2 text-th-heading font-medium">Modifier</th>
              </tr>
            </thead>
            <tbody>
              {ui.size_categories.map((cat: any) => (
                <tr class="border-b border-th-border/5">
                  <td class="py-2.5 pr-4 text-th-body font-medium">{cat.name}</td>
                  <td class="py-2.5 pr-4 text-th-faint hidden sm:table-cell">{cat.examples}</td>
                  <td class:list={[
                    'py-2.5 text-right font-semibold',
                    cat.modifier === 'Baseline' || cat.modifier === 'Base' ? 'text-th-muted' : 'text-brand-accent'
                  ]}>{cat.modifier}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {ui.sensitive_paint && (
          <div class="mt-4 pt-4 border-t border-th-border/8 flex items-center justify-between text-sm">
            <div>
              <span class="text-th-body font-medium">{ui.sensitive_paint}</span>
              <span class="text-th-faint ml-2 text-xs">{ui.sensitive_paint_note}</span>
            </div>
            <span class="text-brand-accent font-semibold">{ui.sensitive_paint_surcharge}</span>
          </div>
        )}
      </div>
    )}

    <!-- Offer Schema (SEO) -->
    {categories.map((category: any) => {
      const offers = category.packages
        .filter((pkg: any) => pkg.price && !pkg.price.toLowerCase().includes('custom') && !pkg.price.toLowerCase().includes('personalizado'))
        .map((pkg: any) => {
          const priceMatch = pkg.price.replace(/\s/g, '').match(/(\d+)/);
          return priceMatch ? {
            "@type": "Offer",
            "name": pkg.name,
            "price": priceMatch[1],
            "priceCurrency": "EUR",
            "url": `${SITE_URL}/${lang}/pricing#${pkg.slug}`,
            "availability": "https://schema.org/InStock"
          } : null;
        })
        .filter(Boolean);
      return offers.length > 0 ? (
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Service",
          "name": serviceType || category.title,
          ...(serviceType ? { "serviceType": serviceType } : {}),
          ...(serviceDescription ? { "description": serviceDescription } : {}),
          ...(serviceAreaServed ? { "areaServed": serviceAreaServed } : {}),
          "provider": { "@type": "AutomotiveBusiness", "name": "restoreLab", "url": SITE_URL },
          "offers": offers
        })} />
      ) : null;
    })}

    <!-- Custom quote CTA -->
    <div class="text-center mt-8 p-8 border border-dashed border-th-border/15 rounded-2xl">
      <p class="text-th-muted mb-4">{t.pricing.cta_custom}</p>
      <a
        href={`https://wa.me/${wa}?text=${encodeURIComponent(categoryId && categories[0] ? t.wa_messages.pricing_custom.replace('{category}', categories[0].title) : t.wa_messages.pricing_custom_general)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <use href="#icon-whatsapp" />
        </svg>
        {t.pricing.cta_whatsapp}
      </a>
    </div>
  </div>
</section>
