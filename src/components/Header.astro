---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
  currentPath?: string;
  availableLangs?: string[];
}

const { t, lang, currentPath = '', availableLangs = ['en', 'es', 'ca'] } = Astro.props;
const wa = WHATSAPP_NUMBER;

// For languages where the current page doesn't exist, link to that language's
// home (/{l}) instead of /{l}{currentPath} — the latter would be a broken URL.
function langHref(l: string): string {
  return availableLangs.includes(l) ? `/${l}${currentPath}` : `/${l}`;
}
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.header)}`;

function isActive(segment: string): boolean {
  if (!segment) return currentPath === '' || currentPath === '/';
  return currentPath === `/${segment}` || currentPath.startsWith(`/${segment}/`);
}
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-th-border/5 bg-brand-dark/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`/${lang}`} class="flex items-center gap-2.5 flex-shrink-0">
        <img src="/favicon.svg" alt="" width="32" height="32" class="w-8 h-8" />
        <span class="font-display font-bold text-xl text-th-heading">
          restore<span class="text-brand-accent">Lab</span>
        </span>
      </a>

      <!-- Nav Desktop -->
      <nav class="hidden md:flex items-center gap-8">
        {[
          { segment: 'services', label: t.nav.services },
          { segment: 'cases',    label: t.nav.cases    },
          { segment: 'pricing',  label: t.nav.pricing  },
          { segment: 'academy',  label: t.nav.academy  },
          { segment: 'contact',  label: t.nav.contact  },
        ].map(({ segment, label }) => (
          <a
            href={`/${lang}/${segment}`}
            class:list={[
              'text-sm transition-colors relative pb-0.5',
              isActive(segment)
                ? 'text-th-heading font-medium after:absolute after:bottom-0 after:left-0 after:right-0 after:h-px after:bg-brand-accent'
                : 'text-th-muted hover:text-th-heading'
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-2 sm:gap-3">

        <!-- Theme Toggle — desktop only -->
        <button
          id="theme-toggle"
          aria-label="Toggle theme"
          class="hidden md:flex items-center justify-center w-9 h-9 rounded-lg text-th-muted hover:text-th-heading hover:bg-th-surface/5 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-[18px] h-[18px] theme-icon-sun" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-[18px] h-[18px] theme-icon-moon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>

        <!-- Language Switcher Dropdown — desktop only -->
        <div class="hidden md:block relative" id="lang-dropdown">
          <button
            id="lang-btn"
            aria-expanded="false"
            aria-haspopup="true"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-th-body/70 hover:text-th-heading hover:bg-th-surface/5 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
          >
            <svg class="w-3.5 h-3.5 text-th-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
            </svg>
            {lang.toUpperCase()}
            <svg class="w-3 h-3 text-th-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            id="lang-menu"
            role="menu"
            class="hidden absolute right-0 top-full mt-1 w-28 bg-brand-dark border border-th-border/10 rounded-xl shadow-2xl overflow-hidden z-50"
          >
            {['en', 'es', 'ca'].map((l) => (
              <a
                href={langHref(l)}
                role="menuitem"
                data-lang-switch={l}
                class:list={[
                  'flex items-center gap-2 px-4 py-2.5 text-sm transition-colors',
                  lang === l
                    ? 'text-brand-accent bg-brand-accent/10 font-medium'
                    : 'text-th-muted hover:text-th-heading hover:bg-th-surface/5'
                ]}
              >
                {l === 'en' && <svg class="w-5 h-3.5 rounded-sm flex-shrink-0" viewBox="0 0 60 30"><clipPath id="uc"><rect width="60" height="30" rx="2"/></clipPath><g clip-path="url(#uc)"><rect width="60" height="30" fill="#012169"/><path d="M0 0L60 30M60 0L0 30" stroke="#fff" stroke-width="6"/><path d="M0 0L60 30M60 0L0 30" stroke="#C8102E" stroke-width="4" clip-path="url(#uc)"/><path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10"/><path d="M30 0v30M0 15h60" stroke="#C8102E" stroke-width="6"/></g></svg>}
                {l === 'es' && <svg class="w-5 h-3.5 rounded-sm flex-shrink-0" viewBox="0 0 750 500"><rect width="750" height="500" fill="#c60b1e"/><rect width="750" height="250" y="125" fill="#ffc400"/></svg>}
                {l === 'ca' && <svg class="w-5 h-3.5 rounded-sm flex-shrink-0" viewBox="0 0 810 540"><rect width="810" height="540" fill="#FCDD09"/><rect width="810" height="60" y="60" fill="#DA121A"/><rect width="810" height="60" y="180" fill="#DA121A"/><rect width="810" height="60" y="300" fill="#DA121A"/><rect width="810" height="60" y="420" fill="#DA121A"/></svg>}
                {l.toUpperCase()}
                {lang === l && (
                  <svg class="w-3 h-3 ml-auto" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>

        <!-- Primary CTA — Book Online -->
        <a
          href={`/${lang}/booking`}
          data-event="nav_book"
          class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 bg-brand-accent hover:bg-blue-500 text-white text-sm font-semibold rounded-lg transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {t.nav.book}
        </a>

        <!-- Theme Toggle — mobile (visible as icon before burger) -->
        <button
          id="theme-toggle-mobile"
          aria-label="Toggle theme"
          class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-th-muted hover:text-th-heading hover:bg-th-surface/5 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
        >
          <svg class="w-[18px] h-[18px] theme-icon-sun" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="w-[18px] h-[18px] theme-icon-moon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>

        <!-- Burger — mobile only -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-th-body/70 hover:text-th-heading focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent rounded-lg"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="burger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-th-border/10 bg-brand-dark" aria-label="Mobile navigation">
    <div class="px-4 py-4 flex flex-col gap-1">

      {[
        { segment: 'services', label: t.nav.services },
        { segment: 'cases',    label: t.nav.cases    },
        { segment: 'pricing',  label: t.nav.pricing  },
        { segment: 'academy',  label: t.nav.academy  },
        { segment: 'contact',  label: t.nav.contact  },
      ].map(({ segment, label }) => (
        <a
          href={`/${lang}/${segment}`}
          class:list={[
            'py-3 px-3 rounded-lg text-sm transition-colors',
            isActive(segment)
              ? 'text-th-heading font-medium bg-th-surface/5 border-l-2 border-brand-accent pl-4'
              : 'text-th-body/70 hover:text-th-heading hover:bg-th-surface/5'
          ]}
        >
          {label}
        </a>
      ))}

      <!-- Language switcher inside mobile menu -->
      <div class="flex items-center gap-2 pt-3 mt-1 border-t border-th-border/10">
        <span class="text-th-faint text-xs uppercase tracking-wider">{t.ui.language}</span>
        <div class="flex items-center gap-1.5 ml-auto">
          {['en', 'es', 'ca'].map((l) => (
            <a
              href={langHref(l)}
              data-lang-switch={l}
              class:list={[
                'flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-semibold border transition-colors',
                lang === l
                  ? 'text-brand-accent border-brand-accent/40 bg-brand-accent/10'
                  : 'text-th-muted border-th-border/10 hover:text-th-heading hover:border-th-border/20'
              ]}
            >
              {l === 'en' && <svg class="w-4 h-3 rounded-sm flex-shrink-0" viewBox="0 0 60 30"><rect width="60" height="30" fill="#012169"/><path d="M0 0L60 30M60 0L0 30" stroke="#fff" stroke-width="6"/><path d="M0 0L60 30M60 0L0 30" stroke="#C8102E" stroke-width="4"/><path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10"/><path d="M30 0v30M0 15h60" stroke="#C8102E" stroke-width="6"/></svg>}
              {l === 'es' && <svg class="w-4 h-3 rounded-sm flex-shrink-0" viewBox="0 0 750 500"><rect width="750" height="500" fill="#c60b1e"/><rect width="750" height="250" y="125" fill="#ffc400"/></svg>}
              {l === 'ca' && <svg class="w-4 h-3 rounded-sm flex-shrink-0" viewBox="0 0 810 540"><rect width="810" height="540" fill="#FCDD09"/><rect width="810" height="60" y="60" fill="#DA121A"/><rect width="810" height="60" y="180" fill="#DA121A"/><rect width="810" height="60" y="300" fill="#DA121A"/><rect width="810" height="60" y="420" fill="#DA121A"/></svg>}
              {l.toUpperCase()}
            </a>
          ))}
        </div>
      </div>

    </div>
  </nav>
</header>

<script>
  // ── Theme toggle ──────────────────────────────────────────────────────
  function initThemeToggle() {
    const html = document.documentElement;

    function syncIcons() {
      const isDark = html.classList.contains('dark');
      document.querySelectorAll('.theme-icon-sun').forEach(el => el.classList.toggle('hidden', !isDark));
      document.querySelectorAll('.theme-icon-moon').forEach(el => el.classList.toggle('hidden', isDark));
    }

    function applyTheme(isDark: boolean) {
      html.classList.toggle('dark', isDark);
      html.classList.toggle('cc--darkmode', isDark);
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', isDark ? '#0A0A0A' : '#FFFFFF');
      syncIcons();
    }

    function toggleTheme() {
      html.classList.add('theme-transitioning');
      const isDark = html.classList.contains('dark');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const newIsDark = !isDark;

      // If toggling back to system default, clear localStorage so OS controls it
      if (newIsDark === systemDark) {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', newIsDark ? 'dark' : 'light');
      }

      applyTheme(newIsDark);

      // Remove transition class after animation
      setTimeout(() => html.classList.remove('theme-transitioning'), 350);
    }

    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

    // Initial icon sync
    syncIcons();
  }

  initThemeToggle();

  // ── Mobile menu toggle ────────────────────────────────────────────────
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('burger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    burgerIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });

  // ── Language dropdown (desktop) ───────────────────────────────────────
  const langBtn = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');

  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !langMenu?.classList.contains('hidden');
    langMenu?.classList.toggle('hidden');
    langBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', () => {
    langMenu?.classList.add('hidden');
    langBtn?.setAttribute('aria-expanded', 'false');
  });

  // ── Persist language preference ───────────────────────────────────────
  document.querySelectorAll<HTMLAnchorElement>('[data-lang-switch]').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = link.dataset.langSwitch;
      if (lang) {
        localStorage.setItem('preferred_lang', lang);
        document.cookie = `preferred_lang=${lang}; path=/; max-age=31536000; SameSite=Lax`;
      }
    });
  });
</script>
