---
import { SITE_URL } from '@/lib/constants';

export interface Props {
  /** Slug of the current academy article */
  slug: string;
  /** Translations object */
  t: Record<string, any>;
  /** Language code */
  lang: string;
}

const { slug, t, lang } = Astro.props;
const contentKey = slug.replace(/-/g, '_');
const content = (t.academy_articles as Record<string, any>)?.[contentKey];

// Render HowTo schema only when:
// 1. The article content has howto: true flag
// 2. The article has structured sections with titles and paragraphs
const isHowTo = content?.howto === true && Array.isArray(content?.sections) && content.sections.length > 0;

let howToJson: object | null = null;
if (isHowTo) {
  howToJson = {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": content.title,
    "description": content.seo_description || content.description,
    "totalTime": content.howto_total_time || undefined, // e.g. "PT2H" — ISO 8601 duration; optional
    "step": content.sections.map((section: any, idx: number) => ({
      "@type": "HowToStep",
      "position": idx + 1,
      "name": section.title,
      "text": (section.paragraphs || []).join(' '),
      "url": `${SITE_URL}/${lang}/academy/${slug}#step-${idx + 1}`,
    })),
  };
}
---

{howToJson && (
  <script type="application/ld+json" set:html={JSON.stringify(howToJson)} />
)}
