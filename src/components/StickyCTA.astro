---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  label: string;
  t: Record<string, any>;
}

const { label, t } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.sticky_cta)}`;
---

<!-- Mobile Sticky CTA -->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden px-4 pt-8 bg-gradient-to-t from-brand-dark via-brand-dark/95 to-transparent" style="padding-bottom: max(1rem, env(safe-area-inset-bottom, 1rem))">
  <a
    href={waUrl}
    target="_blank"
    rel="noopener noreferrer"
    data-event="wa_click"
    class="flex items-center justify-center gap-3 w-full py-4 bg-brand-whatsapp hover:brightness-110 text-white font-semibold rounded-xl text-base transition-all shadow-lg shadow-green-900/30"
  >
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
      <use href="#icon-whatsapp" />
    </svg>
    {label}
  </a>
</div>

<!-- Desktop floating WhatsApp button -->
<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  data-event="wa_click"
  class="hidden md:flex fixed bottom-8 right-8 z-50 w-14 h-14 bg-brand-whatsapp hover:brightness-110 text-white rounded-full items-center justify-center shadow-xl shadow-green-900/40 transition-all hover:scale-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-whatsapp focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
  aria-label="Contact via WhatsApp"
>
  <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
    <use href="#icon-whatsapp" />
  </svg>
</a>
