---
export interface Props {
  t: Record<string, any>;
  /** Kept for call-site compatibility; the block no longer varies by page. */
  equipment?: boolean;
}

const { t } = Astro.props;

// A single monochrome logo wall of the brands we work with — the certification
// cards and the "not sponsors" disclaimer were removed at the owner's request.
// Only brands with a real relationship appear: a logo for a brand we do not use
// would be the false-endorsement problem the fabricated reviews had. Each name
// maps to an asset; brands without one are skipped rather than shown as text.
//
// rupes-mono.png is the RUPES wordmark keyed out of its opaque red source PNG,
// and gtechniq-mono.svg is the GTECHNIQ wordmark with its red plate removed, so
// both sit in a one-colour row cleanly instead of as coloured blocks.
const BRAND_LOGOS: Record<string, string> = {
  'Gyeon': '/images/brands/gyeon.svg',
  'Gtechniq': '/images/brands/gtechniq-mono.svg',
  'Rupes': '/images/brands/rupes-mono.png',
  'Koch Chemie': '/images/brands/koch-chemie.svg',
  'CarPro': '/images/brands/carpro.svg',
  'Sonax': '/images/brands/sonax.svg',
  '3M': '/images/brands/3m.png',
  'Mirka': '/images/brands/mirka.png',
  '3D': '/images/brands/3d.png',
};

const logos = (t.trust?.brands || [])
  .map((b: any) => ({ name: b.name, src: BRAND_LOGOS[b.name] }))
  .filter((b: any) => b.src);
---

{logos.length > 0 && (
  <section class="py-10" aria-labelledby="brands-title">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {t.trust?.certifications_title && (
        <h2 id="brands-title" class="section-title text-center text-2xl md:text-3xl mb-10">
          {t.trust.certifications_title}
        </h2>
      )}

      {/* One treatment for every logo, so the row reads as one system:
          brightness-0 → black on the light theme, dark:invert → white on dark. */}
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-8">
        {logos.map((b: any) => (
          <img
            src={b.src}
            alt={b.name}
            title={b.name}
            loading="lazy"
            class="h-6 sm:h-7 w-auto brightness-0 dark:invert opacity-55 hover:opacity-90 transition-opacity duration-300"
          />
        ))}
      </div>
    </div>
  </section>
)}
