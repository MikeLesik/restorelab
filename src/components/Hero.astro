---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.hero)}`;

// Split H1 on first period: "Restore." / "Don't Replace."
const [h1First, ...h1Rest] = t.hero.headline.split('.');
const h1Second = h1Rest.filter(Boolean).join('.').trim();
---

<section class="relative min-h-screen flex flex-col items-center overflow-hidden bg-gradient-hero pt-16">

  <!-- Background grid -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute inset-0 bg-[linear-gradient(theme(colors.brand.accent/0.3)_1px,transparent_1px),linear-gradient(90deg,theme(colors.brand.accent/0.3)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
  </div>

  <!-- Glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-brand-gold/5 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Top spacer -->
  <div class="flex-1"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- H1 -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-bold text-th-heading mb-6 leading-tight tracking-tight">
      {h1First}.{' '}
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-blue-300">
        {h1Second}.
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-xl md:text-2xl text-th-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      {t.hero.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-3">
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-event="wa_click"
        class="btn-primary text-base px-8 py-4"
      >
        {t.hero.cta_primary}
      </a>
      <a
        href={`/${lang}/cases`}
        data-event="cases_click"
        class="btn-secondary text-base px-8 py-4"
      >
        {t.hero.cta_secondary}
      </a>
    </div>

    <!-- Microcopy -->
    <p class="text-th-faint/80 text-sm">{t.hero.reply_time}</p>

  </div>

  <!-- Trust pills — centered between microcopy and scroll -->
  <div class="flex-1 flex items-center justify-center px-4">
    <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2 max-w-xl">
      {t.hero.trust_pills.map((pill: string, i: number) => (
        <span class:list={[
          "px-1.5 py-1 sm:px-3 sm:py-1.5 rounded-full border border-brand-gold/40 backdrop-blur-sm bg-brand-gold/10 text-brand-gold text-[10px] sm:text-xs font-medium hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-gold/20 transition-all duration-200 cursor-default whitespace-nowrap",
          i === 0 && "animate-pulse"
        ]}>
          {pill}
        </span>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="pb-8 flex flex-col items-center gap-2 text-th-faint/60">
    <span class="text-xs uppercase tracking-widest">{t.ui.scroll}</span>
    <div class="w-px h-8 bg-th-surface/20 animate-pulse"></div>
  </div>

</section>
