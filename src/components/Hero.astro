---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.hero)}`;

// Split H1 on first period: "Restore." / "Don't Replace."
const [h1First, ...h1Rest] = t.hero.headline.split('.');
const h1Second = h1Rest.filter(Boolean).join('.').trim();
---

<section class="relative min-h-screen supports-[height:100svh]:min-h-svh flex flex-col items-center overflow-hidden bg-hero-base pt-16">

  <!-- Background plate: a car body flank under studio light.
       object-position bottom pins the highlight to the lower edge at every
       viewport ratio, so it never crops up into the headline. -->
  <picture class="hero-plate-wrap">
    <source srcset="/images/hero/hero-flank-dark-v1.avif" type="image/avif" />
    <source srcset="/images/hero/hero-flank-dark-v1.webp" type="image/webp" />
    <img
      src="/images/hero/hero-flank-dark-v1.webp"
      alt=""
      aria-hidden="true"
      width="1376"
      height="768"
      fetchpriority="high"
      decoding="async"
      class="hero-plate hero-plate-dark"
    />
  </picture>
  <picture class="hero-plate-wrap">
    <source srcset="/images/hero/hero-flank-light-v1.avif" type="image/avif" />
    <source srcset="/images/hero/hero-flank-light-v1.webp" type="image/webp" />
    <img
      src="/images/hero/hero-flank-light-v1.webp"
      alt=""
      aria-hidden="true"
      width="1376"
      height="768"
      fetchpriority="high"
      decoding="async"
      class="hero-plate hero-plate-light"
    />
  </picture>

  <!-- Scrim: holds the headline zone dark enough for AA contrast, and a
       vignette that keeps the eye centred. Both sit above the plate. -->
  <div class="hero-scrim" aria-hidden="true"></div>

  <!-- Top spacer -->
  <div class="relative z-10 flex-1"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- H1 -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-bold text-th-heading mb-6 leading-tight tracking-tight">
      {h1First}.{' '}
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-blue-700 dark:to-blue-300">
        {h1Second}.
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-xl md:text-2xl text-th-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      {t.hero.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-3">
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-event="wa_click"
        class="btn-primary text-base px-8 py-4"
      >
        {t.hero.cta_primary}
      </a>
      <a
        href={`/${lang}/cases`}
        data-event="cases_click"
        class="btn-secondary text-base px-8 py-4"
      >
        {t.hero.cta_secondary}
      </a>
    </div>

    <!-- Microcopy -->
    <p class="text-th-muted text-sm">{t.hero.reply_time}</p>

  </div>

  <!-- Trust pills — centered between microcopy and scroll -->
  <div class="relative z-10 flex-1 flex items-center justify-center px-4 py-8">
    <div class="flex flex-wrap justify-center gap-x-2 gap-y-2.5 sm:gap-2 max-w-xl">
      {t.hero.trust_pills.map((pill: string, i: number) => (
        <span class:list={[
          "px-1.5 py-1 sm:px-3 sm:py-1.5 rounded-full border border-brand-gold/40 backdrop-blur-sm bg-brand-gold/10 text-brand-gold text-[10px] sm:text-xs font-medium hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-gold/20 transition-all duration-200 cursor-default whitespace-nowrap",
          i === 0 && "animate-pulse"
        ]}>
          {pill}
        </span>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="relative z-10 pb-8 flex flex-col items-center gap-2 text-th-muted/80">
    <span class="text-xs uppercase tracking-widest">{t.ui.scroll}</span>
    <div class="w-px h-8 bg-th-surface/20 animate-pulse"></div>
  </div>

</section>
