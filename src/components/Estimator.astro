---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
  /** Analytics dimension only. Where this instance is rendered. */
  source?: string;
}

const { t, lang, source = 'unknown' } = Astro.props;
const wa = WHATSAPP_NUMBER;
const ui = t.estimator || {};
const waMsg = t.wa_messages || {};
const pricingPath = `/${lang}/pricing`;

// Name, price and duration come from t.pricing ONLY — never from t.estimator.
// t.estimator.tiers carries `desc` and nothing else, keyed by the pricing slug,
// so name/price drift is structurally impossible (commits d650a3d, 69f4dee).
const bySlug: Record<string, any> = {};
for (const cat of t.pricing?.categories ?? []) {
  for (const p of cat.packages ?? []) if (p.slug) bySlug[p.slug] = p;
}

const pkg = (slug: string) => {
  const p = bySlug[slug];
  if (!p) throw new Error(`Estimator: no pricing package for slug "${slug}" in ${lang}.json`);
  return {
    slug,
    name: p.name,
    price: p.price,
    duration: p.duration,
    desc: ui.tiers?.[slug]?.desc || '',
    href: `${pricingPath}#${slug}`,
  };
};

// The whole recommendation engine. 13 rows, no arithmetic, no scoring.
// key = need[:detail][:dark]
const O = (main: string, o: { alt?: string; addon?: string; why?: string } = {}) => ({
  main: pkg(main),
  alt: o.alt ? pkg(o.alt) : null,
  addon: o.addon ? pkg(o.addon) : null,
  why: o.why ? (ui[o.why] || '') : '',
});

const OUTCOMES: Record<string, any> = {
  'paint:light':       O('express-refresh', { alt: 'single-stage', addon: 'headlight-restoration', why: 'why_paint_light' }),
  'paint:light:dark':  O('single-stage',    { alt: 'two-stage',    addon: 'headlight-restoration', why: 'why_paint_light_dark' }),
  'paint:medium':      O('single-stage',    { alt: 'two-stage',    addon: 'headlight-restoration', why: 'why_paint_medium' }),
  'paint:medium:dark': O('two-stage',       {                      addon: 'headlight-restoration', why: 'why_paint_dark' }),
  'paint:heavy':       O('two-stage',       {                      addon: 'headlight-restoration', why: 'why_paint_heavy' }),
  'paint:heavy:dark':  O('two-stage',       {                      addon: 'headlight-restoration', why: 'why_paint_heavy_dark' }),
  'ceramic:2y':        O('ceramic-2y',      { alt: 'premium-5y',   addon: 'windshield-hydrophobic', why: 'why_ceramic_2y' }),
  'ceramic:5y':        O('premium-5y',      {                      addon: 'windshield-hydrophobic', why: 'why_ceramic_5y' }),
  'sale':              O('pre-sale-pack',   {                      addon: 'headlight-restoration', why: 'why_sale' }),
  'glass:windshield':  O('windshield-polish',      { alt: 'windshield-hydrophobic', why: 'why_glass_windshield' }),
  'glass:rain':        O('windshield-hydrophobic', { alt: 'full-glass-set',         why: 'why_glass_rain' }),
  'glass:all':         O('full-glass-set',         {                                why: 'why_glass_all' }),
  'headlights':        O('headlight-restoration',  {                                why: 'why_headlights' }),
  // 'unsure' has no row on purpose — it is the one honest non-answer.
};

const NEEDS = [
  { v: 'paint',      label: ui.need_paint,      q2: 'paint' },
  { v: 'ceramic',    label: ui.need_ceramic,    q2: 'ceramic' },
  { v: 'sale',       label: ui.need_sale,       q2: '' },
  { v: 'glass',      label: ui.need_glass,      q2: 'glass' },
  { v: 'headlights', label: ui.need_headlights, q2: '' },
  { v: 'unsure',     label: ui.need_unsure,     q2: '' },
];

const Q2 = {
  paint: { title: ui.q2_paint_title, opts: [
    { v: 'light',  label: ui.paint_light },
    { v: 'medium', label: ui.paint_medium },
    { v: 'heavy',  label: ui.paint_heavy },
  ]},
  ceramic: { title: ui.q2_ceramic_title, opts: [
    { v: '2y', label: ui.ceramic_2y },
    { v: '5y', label: ui.ceramic_5y },
  ]},
  glass: { title: ui.q2_glass_title, opts: [
    { v: 'windshield', label: ui.glass_windshield },
    { v: 'rain',       label: ui.glass_rain },
    { v: 'all',        label: ui.glass_all },
  ]},
};

const SIZES = [
  { v: 'small',  label: ui.size_small },
  { v: 'medium', label: ui.size_medium },
  { v: 'large',  label: ui.size_large },
];

// Labels for the WhatsApp summary, so the message never carries a raw token.
const LABELS: Record<string, string> = Object.fromEntries([
  ...NEEDS.map((n) => [n.v, n.label]),
  ...Object.values(Q2).flatMap((g) => g.opts.map((o) => [o.v, o.label])),
  ...SIZES.map((s) => [`size_${s.v}`, s.label]),
]);

// WhatsApp copy lives only in t.wa_messages (Critical Rule 3).
const WA = {
  intro:   waMsg.estimator_intro       || '',
  need:    waMsg.estimator_line_need   || '',
  detail:  waMsg.estimator_line_detail || '',
  dark:    waMsg.estimator_line_dark   || '',
  size:    waMsg.estimator_line_size   || '',
  pkgLine: waMsg.estimator_line_pkg    || '',
  addon:   waMsg.estimator_line_addon  || '',
  outro:   waMsg.estimator_outro       || '',
  unsure:  waMsg.estimator_unsure      || '',
};

// Shared option-row classes. peer-checked reaches the nested dot/tick with
// Tailwind 3.4 arbitrary variants, so no global.css rule is needed.
const OPT = [
  'flex items-center gap-3 w-full rounded-xl border border-th-border/15 bg-th-surface/[0.04]',
  'px-4 py-3 text-sm text-th-heading transition-colors cursor-pointer',
  'hover:border-brand-accent/50',
  'peer-checked:border-brand-accent peer-checked:bg-brand-accent/10',
  'peer-checked:[&_.est-dot]:border-brand-accent',
  'peer-checked:[&_.est-tick]:opacity-100',
  'peer-focus-visible:ring-2 peer-focus-visible:ring-brand-accent',
].join(' ');
---

<section id="estimator" class="py-14" aria-labelledby="est-title">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-8">
      <h2 id="est-title" class="section-title mb-2">{ui.title}</h2>
      <p class="text-th-muted text-sm">{ui.subtitle}</p>
    </div>

    <!-- Q1 — always visible, always editable -->
    <fieldset class="mb-6">
      <legend class="text-th-heading font-semibold text-lg mb-3">{ui.q1_title}</legend>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {NEEDS.map((n) => (
          <label class="block">
            <input type="radio" name="est-need" value={n.v} data-q2={n.q2} class="peer sr-only" />
            <span class={OPT}>
              <span aria-hidden="true" class="est-dot w-5 h-5 rounded-full border-2 border-th-border/40 shrink-0 flex items-center justify-center transition-colors">
                <svg class="est-tick w-3 h-3 text-brand-accent opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 24 24" focusable="false">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
              </span>
              <span>{n.label}</span>
            </span>
          </label>
        ))}
      </div>
    </fieldset>

    <!-- Q2 — three groups, at most one visible -->
    {Object.entries(Q2).map(([key, group]) => (
      <fieldset data-est-q2={key} class="est-q2 hidden mb-6">
        <legend class="text-th-heading font-semibold text-lg mb-3">{group.title}</legend>
        <div class="grid grid-cols-1 gap-2">
          {group.opts.map((o) => (
            <label class="block">
              <input type="radio" name={`est-detail-${key}`} value={o.v} class="peer sr-only" />
              <span class={OPT}>
                <span aria-hidden="true" class="est-dot w-5 h-5 rounded-full border-2 border-th-border/40 shrink-0 flex items-center justify-center transition-colors">
                  <svg class="est-tick w-3 h-3 text-brand-accent opacity-0 transition-opacity" fill="currentColor" viewBox="0 0 24 24" focusable="false">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                  </svg>
                </span>
                <span>{o.label}</span>
              </span>
            </label>
          ))}
        </div>

        {key === 'paint' && (
          <>
            <details class="mt-3">
              <summary class="text-xs text-brand-accent cursor-pointer rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent">
                {ui.paint_help_label}
              </summary>
              <p class="text-xs text-th-muted mt-2 pl-3 border-l-2 border-th-border/25">{ui.paint_help}</p>
            </details>

            <label class="mt-3 flex items-center gap-3 text-sm text-th-muted cursor-pointer">
              <input id="est-dark" type="checkbox"
                class="w-5 h-5 rounded border-2 border-th-border/40 accent-brand-accent shrink-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent" />
              <span>{ui.dark_toggle}</span>
            </label>
          </>
        )}
      </fieldset>
    ))}

    <!-- Result — expands, never replaces -->
    <div id="est-result" class="hidden" role="status" aria-live="polite">

      <div id="est-pkg" class="hidden">
        <p class="label text-th-muted mb-2">{ui.result_label}</p>

        <div class="card flex items-start justify-between gap-4 mb-3">
          <div>
            <span id="est-name" class="font-semibold text-th-heading"></span>
            <p id="est-desc" class="text-th-muted text-sm mt-1"></p>
          </div>
          <div class="text-right shrink-0">
            <div id="est-price" class="text-brand-accent font-display font-bold text-xl whitespace-nowrap"></div>
            <div id="est-eta" class="text-th-muted text-xs mt-0.5"></div>
          </div>
        </div>

        <p id="est-why" class="hidden text-sm text-th-body mb-3 border-l-2 border-brand-accent pl-3"></p>

        <p id="est-alt" class="hidden text-sm text-th-muted mb-3">
          <span>{ui.alt_label}</span>{' '}
          <a id="est-alt-link" href={pricingPath}
             class="text-brand-accent font-semibold hover:underline rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"></a>
        </p>

        <!-- the block that has shipped empty since launch -->
        <p id="est-addons" class="hidden text-sm text-th-muted mb-3">
          <span>{ui.addon_label}</span>{' '}
          <a id="est-addon-link" href={pricingPath}
             class="text-brand-accent font-semibold hover:underline rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"></a>
        </p>

        <fieldset class="mb-4">
          <legend class="text-th-muted text-xs mb-2">{ui.size_label}</legend>
          <div class="flex flex-wrap gap-2">
            {SIZES.map((s) => (
              <label class="block">
                <input type="radio" name="est-size" value={s.v} class="peer sr-only" />
                <span class="inline-block rounded-full border border-th-border/15 bg-th-surface/[0.04] px-3 py-1 text-xs text-th-body cursor-pointer transition-colors hover:border-brand-accent/50 peer-checked:border-brand-accent peer-checked:text-brand-accent peer-focus-visible:ring-2 peer-focus-visible:ring-brand-accent">
                  {s.label}
                </span>
              </label>
            ))}
          </div>
          <p class="text-th-muted text-xs mt-2">{ui.size_hint}</p>
        </fieldset>
      </div>

      <div id="est-unsure" class="hidden card mb-4">
        <p class="font-semibold text-th-heading mb-1">{ui.unsure_title}</p>
        <p class="text-th-muted text-sm">{ui.unsure_body}</p>
      </div>

      <p class="text-th-muted text-xs mb-4">{ui.honesty}</p>

      <a id="est-wa" href="#" target="_blank" rel="noopener noreferrer"
         data-event="estimator_wa" class="btn-whatsapp w-full">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <use href="#icon-whatsapp" />
        </svg>
        {ui.cta_whatsapp}
      </a>
      <p class="text-th-muted text-xs text-center mt-2">{ui.cta_whatsapp_hint}</p>

      <div class="flex flex-col items-center gap-2 mt-4">
        <a id="est-pkg-link" href={pricingPath} data-event="estimator_pkg_detail"
           class="hidden text-sm text-brand-accent hover:underline rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent">
          {ui.see_package}
        </a>
        <a href={`/${lang}/booking`} data-event="estimator_book"
           class="text-sm text-th-muted hover:text-th-heading transition-colors rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent">
          {ui.cta_booking}
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ wa, OUTCOMES, LABELS, WA, source }}>
  const $ = (id) => document.getElementById(id);
  const state = { need: '', detail: '', dark: false, size: '' };
  let started = false, scrolled = false, current = null;

  const show = (el, on) => el && el.classList.toggle('hidden', !on);

  function key() {
    if (!state.need || state.need === 'unsure') return state.need;
    const q2 = document.querySelector(`[data-est-q2="${state.need}"]`);
    if (q2 && !state.detail) return '';            // waiting on Q2
    let k = q2 ? `${state.need}:${state.detail}` : state.need;
    if (state.need === 'paint' && state.dark) k += ':dark';
    return k;
  }

  // Assemble the WhatsApp message from t.wa_messages line keys, omitting any
  // line whose value is empty — no "• Estado: " blanks reach the technician.
  function buildMessage(o) {
    const lines = [WA.intro];
    if (LABELS[state.need]) lines.push(WA.need.replace('{need}', LABELS[state.need]));
    if (LABELS[state.detail]) lines.push(WA.detail.replace('{detail}', LABELS[state.detail]));
    if (state.dark) lines.push(WA.dark);
    if (state.size) lines.push(WA.size.replace('{size}', LABELS['size_' + state.size]));
    lines.push(
      WA.pkgLine
        .replace('{tierName}', o.main.name)
        .replace('{price}', o.main.price)
        .replace('{duration}', o.main.duration)
    );
    if (o.addon) {
      lines.push(WA.addon.replace('{addon}', o.addon.name).replace('{addonPrice}', o.addon.price));
    }
    return lines.filter(Boolean).join('\n') + '\n\n' + WA.outro;
  }

  function render() {
    const k = key();
    if (!k) { show($('est-result'), false); current = null; return; }

    if (k === 'unsure') {
      show($('est-pkg'), false);
      show($('est-unsure'), true);
      show($('est-pkg-link'), false);
      $('est-wa').href = `https://wa.me/${wa}?text=${encodeURIComponent(WA.unsure)}`;
      if (current !== 'unsure') {
        current = 'unsure';
        window.__rl_push?.({ event: 'estimator_result', source, need: 'unsure', slug: null, price: null });
      }
    } else {
      const o = OUTCOMES[k];
      if (!o) { show($('est-result'), false); return; }
      show($('est-unsure'), false);
      show($('est-pkg'), true);

      $('est-name').textContent  = o.main.name;
      $('est-desc').textContent  = o.main.desc;
      $('est-price').textContent = o.main.price;
      $('est-eta').textContent   = o.main.duration;

      $('est-why').textContent = o.why;
      show($('est-why'), !!o.why);

      if (o.alt) {
        $('est-alt-link').textContent = `${o.alt.name} — ${o.alt.price}`;
        $('est-alt-link').href = o.alt.href;
      }
      show($('est-alt'), !!o.alt);

      if (o.addon) {
        $('est-addon-link').textContent = `${o.addon.name} — ${o.addon.price}`;
        $('est-addon-link').href = o.addon.href;
      }
      show($('est-addons'), !!o.addon);

      $('est-pkg-link').href = o.main.href;
      show($('est-pkg-link'), true);

      $('est-wa').href = `https://wa.me/${wa}?text=${encodeURIComponent(buildMessage(o))}`;

      if (current !== k) {
        current = k;
        window.__rl_push?.({
          event: 'estimator_result', source,
          need: state.need, detail: state.detail || null, dark: state.dark,
          slug: o.main.slug, price: o.main.price,
        });
      }
    }

    show($('est-result'), true);
    if (!scrolled) {
      scrolled = true;
      $('est-result').scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  }

  document.querySelectorAll('input[name="est-need"]').forEach((r) =>
    r.addEventListener('change', () => {
      if (!started) { started = true; window.__rl_push?.({ event: 'estimator_started', source }); }
      state.need = r.value; state.detail = ''; state.dark = false; state.size = '';
      if ($('est-dark')) $('est-dark').checked = false;
      document.querySelectorAll('.est-q2').forEach((g) => show(g, g.dataset.estQ2 === r.dataset.q2));
      document.querySelectorAll('.est-q2 input[type=radio], input[name="est-size"]')
        .forEach((i) => { i.checked = false; });
      render();
    })
  );

  document.querySelectorAll('.est-q2 input[type=radio]').forEach((r) =>
    r.addEventListener('change', () => { state.detail = r.value; render(); })
  );

  $('est-dark')?.addEventListener('change', (e) => { state.dark = e.target.checked; render(); });

  document.querySelectorAll('input[name="est-size"]').forEach((r) =>
    r.addEventListener('change', () => { state.size = r.value; render(); })
  );
</script>
