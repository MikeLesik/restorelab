---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;
const waUrl = `https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.footer)}`;
---

<footer class="bg-brand-navy border-t border-th-border/10 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`/${lang}`} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-brand-accent rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="font-display font-bold text-xl text-th-heading">
            restore<span class="text-brand-accent">Lab</span>
          </span>
        </a>
        <p class="text-th-muted text-sm leading-relaxed">{t.footer.tagline}</p>
        {t.footer.trust && (
          <p class="text-th-faint text-xs mt-2">{t.footer.trust}</p>
        )}
        <div class="flex items-center gap-3 mt-4">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-brand-whatsapp hover:brightness-125 transition-all"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <use href="#icon-whatsapp" />
            </svg>
            <span class="text-sm font-medium">{`+${wa.slice(0,2)} ${wa.slice(2,5)} ${wa.slice(5,8)} ${wa.slice(8)}`}</span>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-th-heading font-semibold mb-4 text-sm uppercase tracking-widest">{t.footer.services_title}</h3>
        <ul class="space-y-2">
          {t.services.items.filter((s: any) => !['trim-restoration'].includes(s.id)).map((s: any) => (
            <li>
              <a href={`/${lang}/services/${s.id}`} class="text-th-muted hover:text-th-heading text-sm transition-colors">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-th-heading font-semibold mb-4 text-sm uppercase tracking-widest">{t.footer.company_title || 'Company'}</h3>
        <ul class="space-y-2 text-sm text-th-muted">
          <li>
            <a href={`/${lang}/about`} class="hover:text-th-heading transition-colors">
              {t.trust?.founder?.link_label || 'About us'}
            </a>
          </li>
          <li>
            <a href={`/${lang}/business`} class="hover:text-th-heading transition-colors">
              {t.footer.business_link || 'For Business'}
            </a>
          </li>
          <li>
            <a href={`/${lang}/ev`} class="hover:text-th-heading transition-colors">
              {t.footer.ev_link || 'EV Protection'}
            </a>
          </li>
          <li>
            <a href={`/${lang}/commercial-glass`} class="hover:text-th-heading transition-colors">
              {t.footer.commercial_glass_link || 'Commercial Glass'}
            </a>
          </li>
          <li>
            <a href={`/${lang}/plans`} class="hover:text-th-heading transition-colors">
              {t.footer.plans_link || 'Care Plans'}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-th-heading font-semibold mb-4 text-sm uppercase tracking-widest">{t.footer.contact_title}</h3>
        <ul class="space-y-2 text-sm text-th-muted">
          <li>
            <a href={waUrl} target="_blank" rel="noopener noreferrer" class="hover:text-th-heading transition-colors">
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`tel:+${wa}`} data-event="footer_phone" class="hover:text-th-heading transition-colors">
              +34 680 265 190
            </a>
          </li>
          <li>
            <a href="mailto:support@restorelab.io" data-event="footer_email" class="hover:text-th-heading transition-colors">
              support@restorelab.io
            </a>
          </li>
          <li>
            <a href={`/${lang}/contact`} class="hover:text-th-heading transition-colors">
              {t.nav.contact}
            </a>
          </li>
          <li>
            <a href={`/${lang}/booking`} class="hover:text-th-heading transition-colors">
              {t.footer.booking_link || 'Book Online'}
            </a>
          </li>
          {t.footer.gbp_url && (
            <li>
              <a href={t.footer.gbp_url} target="_blank" rel="noopener noreferrer" class="hover:text-th-heading transition-colors">
                {t.footer.gbp_label || 'Google Reviews'}
              </a>
            </li>
          )}
        </ul>
        {t.footer.legal_entity && (
          <div class="mt-4 pt-4 border-t border-th-border/10">
            <p class="text-th-faint text-xs">{t.footer.legal_entity}</p>
          </div>
        )}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-th-border/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-th-faint text-sm">{t.footer.copyright}</p>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-sm">
        <a href={`/${lang}/legal`} class="text-th-faint hover:text-th-heading transition-colors">
          {t.footer.legal_notice_label || 'Legal notice'}
        </a>
        <span class="text-th-border/40" aria-hidden="true">·</span>
        <a href={`/${lang}/privacy`} class="text-th-faint hover:text-th-heading transition-colors">
          {t.footer.privacy}
        </a>
        <span class="text-th-border/40" aria-hidden="true">·</span>
        <a href={`/${lang}/cookies`} class="text-th-faint hover:text-th-heading transition-colors">
          {t.footer.cookies_label || 'Cookies'}
        </a>
        <span class="text-th-border/40" aria-hidden="true">·</span>
        <a href={`/${lang}/terms`} class="text-th-faint hover:text-th-heading transition-colors">
          {t.footer.terms}
        </a>
      </div>
      <p class="text-th-faint text-sm">{t.footer.made_in}</p>
    </div>
  </div>
</footer>
