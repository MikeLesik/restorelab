---
export interface Props {
  t: Record<string, any>;
}

const { t } = Astro.props;
const brands = t.trust?.brands || [
  { name: 'Gyeon', status: 'authorized' },
  { name: 'Gtechniq', status: 'authorized' },
  { name: 'Rupes', status: 'equipment' },
  { name: 'Koch Chemie', status: 'equipment' },
  { name: 'CarPro', status: 'products' },
];

// Official brand assets in /public/images/brands.
// Per-asset filters keep every logo visible in BOTH themes:
// - white-fill SVGs (Gyeon, CarPro) → black silhouette in light, natural white in dark
// - grey SVG (Koch Chemie) → natural in light, forced white in dark
// - red-plate marks (Gtechniq, Rupes) → grayscale plate in both, color on hover
const logoMap: Record<string, { src: string; cls?: string }> = {
  'Gyeon':       { src: '/images/brands/gyeon.svg', cls: 'brightness-0 dark:brightness-100' },
  'Gtechniq':    { src: '/images/brands/gtechniq.svg', cls: 'grayscale hover:grayscale-0' },
  'Rupes':       { src: '/images/brands/rupes.png', cls: 'grayscale hover:grayscale-0' },
  'Koch Chemie': { src: '/images/brands/koch-chemie.svg', cls: 'dark:brightness-0 dark:invert' },
  'CarPro':      { src: '/images/brands/carpro.svg', cls: 'brightness-0 dark:brightness-100' },
};
---

<section class="py-6 border-y border-th-border/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
      {brands.map((brand: any) => {
        const logo = logoMap[brand.name];
        return logo ? (
          <img
            src={logo.src}
            alt={brand.name}
            title={brand.name}
            loading="lazy"
            class:list={['h-6 sm:h-7 w-auto opacity-60 dark:opacity-50 hover:opacity-100 transition-all duration-300', logo.cls]}
          />
        ) : (
          <span class="font-display font-bold text-th-muted text-sm sm:text-base tracking-wide opacity-40">
            {brand.name}
          </span>
        );
      })}
    </div>
  </div>
</section>
