---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
}

// `lang` is an explicit prop, not a read of `t.lang`: a broken contract then
// fails `astro check` (ts2322) instead of silently emitting /undefined/areas/*.
const { t, lang } = Astro.props;
const wa = WHATSAPP_NUMBER;

const hubIcons = [
  /* Barcelona — anchor (marinas + port city) */
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1M4.22 4.22l.707.707m12.02 12.02.708.708M1 12h2m18 0h2M4.929 19.071l.707-.707M18.364 4.929l.708-.708"/>
   <circle cx="12" cy="12" r="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`,
  /* Sant Cugat — city skyline / bridge */
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M5 21V10l7-7 7 7v11M9 21v-5h6v5"/>`,
  /* Terrassa — sun (Vallès = sun coast) */
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2m0 14v2M5.636 5.636l1.414 1.414m8.9 8.9 1.415 1.414M3 12h2m14 0h2M5.636 18.364l1.414-1.414m8.9-8.9 1.415-1.414"/>
   <circle cx="12" cy="12" r="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`,
];
---

<section class="pt-10 pb-14 relative overflow-hidden">

  <!-- Subtle Spain silhouette background decoration -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-[0.03] pointer-events-none select-none" aria-hidden="true">
    <svg width="340" height="480" viewBox="0 0 340 480" fill="white" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 10 L280 25 L310 60 L320 110 L315 160 L300 200 L310 240 L295 280
               L270 310 L230 340 L200 370 L175 400 L155 430 L140 460 L130 470
               L110 465 L80 450 L50 420 L30 380 L20 340 L25 290 L15 250
               L10 200 L20 150 L30 110 L50 75 L80 45 L120 20 Z"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <h2 class="section-title">{t.area.section_title}</h2>
      <p class="section-subtitle mx-auto">{t.area.section_subtitle}</p>
    </div>

    <!-- 3 City Hub Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {t.area.hubs.map((hub: any, i: number) => (
        <div class="group relative rounded-2xl border border-th-border/10 bg-th-surface/5 backdrop-blur-sm p-7 flex flex-col hover:border-brand-accent/30 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-brand-accent/5">

          {/* Top accent line */}
          <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-brand-accent/60 to-transparent rounded-full"></div>

          {/* Hub number */}
          <div class="absolute top-5 right-5 w-6 h-6 rounded-full bg-th-surface/5 border border-th-border/10 flex items-center justify-center">
            <span class="text-[10px] font-bold text-th-faint">{i + 1}</span>
          </div>

          {/* Icon */}
          <div class="w-12 h-12 rounded-xl bg-brand-accent/10 border border-brand-accent/20 flex items-center justify-center mb-5 group-hover:bg-brand-accent/20 transition-colors">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={hubIcons[i]} />
          </div>

          {/* City + region */}
          <h3 class="font-display font-bold text-th-heading text-2xl mb-0.5">{hub.city}</h3>
          <p class="label mb-4">{hub.region}</p>

          {/* Coverage badge */}
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-brand-accent/10 border border-brand-accent/15 rounded-full mb-5 self-start">
            <svg class="w-3 h-3 text-brand-accent/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <circle cx="12" cy="11" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
            <span class="text-xs text-brand-accent/80 font-medium">{hub.coverage}</span>
          </div>

          {/* Coverage towns — a clean middot-separated list reads far better than
              the ragged bordered chips it replaced. */}
          <p class="text-sm text-th-muted leading-relaxed mb-7 flex-1">
            {hub.areas.join('  ·  ')}
          </p>

          {/* CTA */}
          <a
            href={`https://wa.me/${wa}?text=${encodeURIComponent(t.wa_messages.area_quote.replace('{city}', hub.city))}`}
            target="_blank"
            rel="noopener noreferrer"
            data-event="wa_click"
            class="flex items-center justify-center gap-2 w-full py-2.5 text-sm font-semibold text-white bg-brand-whatsapp/90 hover:bg-brand-whatsapp rounded-xl transition-all"
          >
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <use href="#icon-whatsapp" />
            </svg>
            {t.area.cta_prefix} {hub.city}
          </a>
        </div>
      ))}
    </div>

    <!-- Full coverage index. The only non-geo page that links every area page,
         so the 12-page cluster is not a closed clique: /contact is in the main
         nav, which puts every city page at crawl depth 2 in every language.
         Sits above the travel note on purpose — list the towns we have pages
         for, then tell everyone else we still travel. -->
    <div class="mt-12 pt-8 border-t border-th-border/10 max-w-3xl mx-auto">
      <h3 class="text-center font-display font-semibold text-th-heading text-lg mb-1.5">
        {t.area.all_areas_title}
      </h3>
      <p class="text-center caption mb-6">{t.area.all_areas_subtitle}</p>

      <nav aria-label={t.area.all_areas_title}>
        <ul class="flex flex-wrap justify-center gap-2">
          {t.area_pages.cities.map((c: any) => (
            <li>
              <a
                href={`/${lang}/areas/${c.slug}`}
                class="inline-flex items-center px-4 py-2 rounded-full bg-th-surface/5 border border-th-border/10 text-th-body text-sm hover:text-brand-accent hover:border-brand-accent/40 hover:bg-brand-accent/5 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
                data-event="area_index_click"
              >
                {c.short}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Travel note -->
    <p class="text-center caption mt-8">{t.area.travel_note}</p>

  </div>
</section>
