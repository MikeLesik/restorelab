---
import { WHATSAPP_NUMBER } from '@/lib/constants';
import { serviceIcons } from '@/lib/icons';

export interface Props {
  t: Record<string, any>;
  lang: string;
  compact?: boolean;
  exclude?: string[];
}

const { t, lang, compact = false, exclude = [] } = Astro.props;

// Service ids that have a dedicated page. The grid also renders
// `trim-restoration`, which has none, so that card must stay unlinked.
const SERVICE_PAGES = new Set([
  'car-paint-correction',
  'glass-polishing',
  'acrylic-restoration',
  'headlight-restoration',
  'pre-sale-pack',
]);
const wa = WHATSAPP_NUMBER;
const services = t.services.items.filter((s: any) => !exclude.includes(s.id));

// Before/after banner per service. Illustrations (generated), not customer
// cases — a single note under the grid says so, so the cards cannot read as
// real results the way the deleted yacht case did. A service without an image
// falls back to its icon.
const serviceImages: Record<string, string> = {
  'car-paint-correction': '/images/cases/realcar-suv-black',
  'glass-polishing': '/images/cases/glass-windshield-front',
  'headlight-restoration': '/images/cases/moto-headlight-round',
  'acrylic-restoration': '/images/cases/moto-acrylic-screen',
  'pre-sale-pack': '/images/cases/realcar-hothatch-red',
};

// Per-service visual config
const serviceConfig: Record<string, { color: string; iconBg: string; borderTop: string; iconPaths: string }> = {
  'car-paint-correction': {
    color: 'text-brand-accent',
    iconBg: 'bg-brand-accent/15 group-hover:bg-brand-accent/25',
    borderTop: 'border-t-2 border-brand-accent/60',
    iconPaths: serviceIcons['car-paint-correction'],
  },
  'glass-polishing': {
    color: 'text-cyan-600 dark:text-cyan-400',
    iconBg: 'bg-cyan-500/15 group-hover:bg-cyan-500/25',
    borderTop: 'border-t-2 border-cyan-500/50',
    iconPaths: serviceIcons['glass-polishing'],
  },
  'acrylic-restoration': {
    color: 'text-violet-600 dark:text-violet-400',
    iconBg: 'bg-violet-500/15 group-hover:bg-violet-500/25',
    borderTop: 'border-t-2 border-violet-500/50',
    iconPaths: serviceIcons['acrylic-restoration'],
  },
  'headlight-restoration': {
    color: 'text-amber-600 dark:text-amber-400',
    iconBg: 'bg-amber-500/15 group-hover:bg-amber-500/25',
    borderTop: 'border-t-2 border-amber-500/50',
    iconPaths: serviceIcons['headlight-restoration'],
  },
  'trim-restoration': {
    color: 'text-slate-600 dark:text-slate-400',
    iconBg: 'bg-slate-500/15 group-hover:bg-slate-500/25',
    borderTop: 'border-t-2 border-slate-500/50',
    iconPaths: serviceIcons['trim-restoration'],
  },
  'pre-sale-pack': {
    color: 'text-brand-gold',
    iconBg: 'bg-brand-gold/15 group-hover:bg-brand-gold/25',
    borderTop: 'border-t-2 border-brand-gold/50',
    iconPaths: serviceIcons['pre-sale-pack'],
  },
};

function getColsClass(count: number): string {
  if (count <= 3) return 'grid-cols-1 md:grid-cols-3';
  if (count <= 4) return 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4';
  return 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
}
const colsClass = getColsClass(services.length);
---

{/* border-t terminates the full-viewport Hero. BrandsStrip used to provide this
    seam; with it gone, ServicesGrid — now the first section after the Hero on
    the homepage — carries it. `compact` (the /services listing) has its own h1
    above and needs no seam. */}
<section class={compact ? '' : 'pt-16 pb-20 border-t border-th-border/5'}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact && (
      <div class="text-center mb-10">
        <h2 class="section-title">{t.services.section_title}</h2>
        <p class="section-subtitle mx-auto">{t.services.section_subtitle}</p>
      </div>
    )}

    <div class:list={['grid gap-6', colsClass]}>
      {services.map((service: any) => {
        const cfg = serviceConfig[service.id] ?? serviceConfig['car-paint-correction'];
        const isFeatured = service.tag === 'Most popular' || service.tag === 'Más popular' || service.tag === 'Més popular';
        const ctaLabel = service.cta_label ?? t.services.get_quote;
        const waText = encodeURIComponent(t.wa_messages.services_grid_quote.replace('{service}', service.title));
        const serviceHref = SERVICE_PAGES.has(service.id) ? `/${lang}/services/${service.id}` : null;
        const img = serviceImages[service.id];

        return (
          <div class:list={[
            'group relative rounded-2xl border bg-th-surface/5 backdrop-blur-sm overflow-hidden flex flex-col',
            'transition-all duration-300 hover:-translate-y-1 hover:shadow-xl',
            cfg.borderTop,
            isFeatured
              ? 'border-brand-accent/30 bg-gradient-to-b from-brand-accent/5 to-th-surface/[0.03] hover:border-brand-accent/50'
              : 'border-th-border/10 hover:border-th-border/20'
          ]}>

            {/* Featured glow ring */}
            {isFeatured && (
              <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-brand-accent/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10"></div>
            )}

            {/* Before/after banner (illustrative) — replaces the icon. Falls back
                to the icon plate when a service has no image. */}
            {img ? (
              <div class="relative aspect-video overflow-hidden">
                <picture>
                  <source srcset={`${img}.webp`} type="image/webp" />
                  <img src={`${img}.jpg`} alt={`${t.services.illustration_before} / ${t.services.illustration_after} — ${service.title}`}
                       class="w-full h-full object-cover" width="800" height="450" loading="lazy" decoding="async" />
                </picture>
                <span class="absolute top-2.5 left-2.5 px-2 py-0.5 bg-black/85 rounded text-[10px] text-white uppercase tracking-wider">{t.services.illustration_before}</span>
                <span class="absolute top-2.5 right-2.5 px-2 py-0.5 bg-black/85 border border-brand-accent rounded text-[10px] text-white uppercase tracking-wider">{t.services.illustration_after}</span>
              </div>
            ) : (
              <div class="p-6 pb-0">
                <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center', cfg.iconBg]}>
                  <svg class:list={['w-6 h-6', cfg.color]} fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" focusable="false" set:html={cfg.iconPaths} />
                </div>
              </div>
            )}

            <div class="p-6 flex flex-col flex-1">

            {service.tag && (
              <span class:list={[
                'self-start text-xs font-semibold px-3 py-1 rounded-full border mb-3',
                isFeatured
                  ? 'bg-brand-accent/10 text-brand-accent border-brand-accent/25'
                  : 'bg-brand-gold/10 text-brand-gold border-brand-gold/20'
              ]}>
                {service.tag}
              </span>
            )}

            {/* Title — doubles as the card's link to the service page. The
                ::after overlay stretches it across the whole card, which is why
                the WhatsApp CTA below needs its own stacking context: anchors
                cannot be nested. */}
            <h3 class="text-xl font-display font-bold text-th-heading mb-1">
              {serviceHref ? (
                <a
                  href={serviceHref}
                  class="after:absolute after:inset-0 after:content-[''] after:rounded-2xl hover:text-brand-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark rounded"
                >
                  {service.title}
                </a>
              ) : service.title}
            </h3>

            {/* Subtitle — 1 line */}
            <p class="text-sm text-th-muted mb-5 leading-snug">{service.subtitle}</p>

            {/* Features — exactly 3 bullets, flex-1 to push price+CTA down */}
            <ul class="space-y-2.5 mb-5 flex-1">
              {service.features.map((f: string) => (
                <li class="flex items-center gap-2.5 text-sm text-th-body/80">
                  <svg class:list={['w-4 h-4 flex-shrink-0', cfg.color]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            {/* Price */}
            {service.starting_price && (
              <div class="mb-4 pb-4 border-b border-th-border/10">
                <span class:list={['font-bold text-lg', cfg.color]}>{service.starting_price}</span>
              </div>
            )}

            {/* CTA — uniform green WhatsApp button on all cards */}
            <a
              href={`https://wa.me/${wa}?text=${waText}`}
              target="_blank"
              rel="noopener noreferrer"
              data-event="wa_click"
              class="relative z-10 mt-auto flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-brand-whatsapp hover:brightness-110 text-white text-sm font-semibold rounded-lg transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-whatsapp focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
            >
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <use href="#icon-whatsapp" />
              </svg>
              {ctaLabel}
            </a>
            <p class="text-center text-th-faint text-[10px] mt-2 tracking-wide">{t.trust.micro_service}</p>

            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
