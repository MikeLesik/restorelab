---
import { WHATSAPP_NUMBER } from '@/lib/constants';

export interface Props {
  t: Record<string, any>;
  lang: string;
  compact?: boolean;
  exclude?: string[];
}

const { t, lang, compact = false, exclude = [] } = Astro.props;
const wa = WHATSAPP_NUMBER;
const services = t.services.items.filter((s: any) => !exclude.includes(s.id));

// Per-service visual config
const serviceConfig: Record<string, { color: string; iconBg: string; borderTop: string; iconPaths: string }> = {
  'car-paint-correction': {
    color: 'text-brand-accent',
    iconBg: 'bg-brand-accent/15 group-hover:bg-brand-accent/25',
    borderTop: 'border-t-2 border-brand-accent/60',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 11l2-5h10l2 5M3 11h18v4a1 1 0 01-1 1H4a1 1 0 01-1-1v-4z"/><circle cx="7.5" cy="17.5" r="1.5"/><circle cx="16.5" cy="17.5" r="1.5"/>`,
  },
  'glass-polishing': {
    color: 'text-cyan-400',
    iconBg: 'bg-cyan-500/15 group-hover:bg-cyan-500/25',
    borderTop: 'border-t-2 border-cyan-500/50',
    iconPaths: `<rect x="3" y="4" width="18" height="16" rx="2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12h18M12 4v16"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7.5 8l1 1.5" opacity="0.5"/>`,
  },
  'acrylic-restoration': {
    color: 'text-violet-400',
    iconBg: 'bg-violet-500/15 group-hover:bg-violet-500/25',
    borderTop: 'border-t-2 border-violet-500/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
  },
  'headlight-restoration': {
    color: 'text-amber-400',
    iconBg: 'bg-amber-500/15 group-hover:bg-amber-500/25',
    borderTop: 'border-t-2 border-amber-500/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.674M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
  },
  'trim-restoration': {
    color: 'text-slate-400',
    iconBg: 'bg-slate-500/15 group-hover:bg-slate-500/25',
    borderTop: 'border-t-2 border-slate-500/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>`,
  },
  'wheel-ceramic': {
    color: 'text-orange-400',
    iconBg: 'bg-orange-500/15 group-hover:bg-orange-500/25',
    borderTop: 'border-t-2 border-orange-500/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/><circle cx="12" cy="12" r="3" stroke-width="1.5"/>`,
  },
  'engine-bay': {
    color: 'text-emerald-400',
    iconBg: 'bg-emerald-500/15 group-hover:bg-emerald-500/25',
    borderTop: 'border-t-2 border-emerald-500/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.573-1.066z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  'interior-leather': {
    color: 'text-amber-600',
    iconBg: 'bg-amber-600/15 group-hover:bg-amber-600/25',
    borderTop: 'border-t-2 border-amber-600/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  'pre-sale-pack': {
    color: 'text-brand-gold',
    iconBg: 'bg-brand-gold/15 group-hover:bg-brand-gold/25',
    borderTop: 'border-t-2 border-brand-gold/50',
    iconPaths: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
};

function getColsClass(count: number): string {
  if (count <= 3) return 'grid-cols-1 md:grid-cols-3';
  if (count <= 4) return 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4';
  return 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
}
const colsClass = getColsClass(services.length);
---

<section class={compact ? '' : 'pt-16 pb-20'}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact && (
      <div class="text-center mb-10">
        <h2 class="section-title">{t.services.section_title}</h2>
        <p class="section-subtitle mx-auto">{t.services.section_subtitle}</p>
      </div>
    )}

    <div class:list={['grid gap-6', colsClass]}>
      {services.map((service: any) => {
        const cfg = serviceConfig[service.id] ?? serviceConfig['car-paint-correction'];
        const isFeatured = service.tag === 'Most popular' || service.tag === 'Más popular' || service.tag === 'Més popular';
        const ctaLabel = service.cta_label ?? t.services.get_quote;
        const waText = encodeURIComponent(`Hello restoreLab! I'd like a quote for: ${service.title}`);

        return (
          <div class:list={[
            'group relative rounded-2xl border bg-th-surface/5 backdrop-blur-sm p-6 flex flex-col',
            'transition-all duration-300 hover:-translate-y-1 hover:shadow-xl',
            cfg.borderTop,
            isFeatured
              ? 'border-brand-accent/30 bg-gradient-to-b from-brand-accent/5 to-th-surface/[0.03] hover:border-brand-accent/50'
              : 'border-th-border/10 hover:border-th-border/20'
          ]}>

            {/* Featured glow ring */}
            {isFeatured && (
              <div class="absolute -inset-px rounded-2xl bg-gradient-to-b from-brand-accent/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            )}

            {/* Icon + tag */}
            <div class="flex items-start justify-between mb-5">
              <div class:list={[
                'w-12 h-12 rounded-xl flex items-center justify-center transition-colors duration-200',
                cfg.iconBg
              ]}>
                <svg
                  class:list={['w-6 h-6', cfg.color]}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  set:html={cfg.iconPaths}
                />
              </div>

              {service.tag && (
                <span class:list={[
                  'text-xs font-semibold px-3 py-1 rounded-full border',
                  isFeatured
                    ? 'bg-brand-accent/10 text-brand-accent border-brand-accent/25 animate-pulse'
                    : 'bg-brand-gold/10 text-brand-gold border-brand-gold/20'
                ]}>
                  {service.tag}
                </span>
              )}
            </div>

            {/* Title */}
            <h3 class="text-xl font-display font-bold text-th-heading mb-1">{service.title}</h3>

            {/* Subtitle — 1 line */}
            <p class="text-sm text-th-muted mb-5 leading-snug">{service.subtitle}</p>

            {/* Features — exactly 3 bullets, flex-1 to push price+CTA down */}
            <ul class="space-y-2.5 mb-5 flex-1">
              {service.features.map((f: string) => (
                <li class="flex items-center gap-2.5 text-sm text-th-body/80">
                  <svg class:list={['w-4 h-4 flex-shrink-0', cfg.color]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            {/* Price */}
            {service.starting_price && (
              <div class="mb-4 pb-4 border-b border-th-border/8">
                <span class:list={['font-bold text-lg', cfg.color]}>{service.starting_price}</span>
              </div>
            )}

            {/* CTA — uniform green WhatsApp button on all cards */}
            <a
              href={`https://wa.me/${wa}?text=${waText}`}
              target="_blank"
              rel="noopener noreferrer"
              data-event="wa_click"
              class="mt-auto flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-brand-whatsapp hover:brightness-110 text-white text-sm font-semibold rounded-lg transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-whatsapp focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
            >
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {ctaLabel}
            </a>
            <p class="text-center text-th-faint text-[10px] mt-2 tracking-wide">{t.trust.micro_service}</p>

          </div>
        );
      })}
    </div>
  </div>
</section>
